---
/**
 * PerfectLoopGallery.astro
 * 
 * A completely vanilla JS Astro component providing a perfectly looping, 
 * lightweight gallery with smooth fade transitions. 
 * 
 * Features:
 * - Perfect infinite loop logic (both forwards and backwards)
 * - Smooth fade transitions with no visual tearing 
 * - Play/Pause autoplay controls
 * - Synced dot navigation
 * - Current slide counter
 * - Fully responsive & accessible (Keyboard navigation & ARIA hints)
 * - Graceful fallback (Controls automatically hide if only 1 image rests in the array)
 * 
 * Note on `client:load`: Because this is built purely as an .astro component, 
 * the script block inside it automatically bundles and executes natively on the client 
 * for maximum performance. You DO NOT need to add the `client:load` directive when 
 * importing it into your pages! (That directive is only required for React/Vue/Svelte).
 */

export interface ImageProps {
  src: string;
  alt: string;
  title?: string;
}

export interface Props {
  images: ImageProps[];
  /** Optional Autoplay Toggle (Defaults to false) */
  autoplay?: boolean;
}

const { images = [], autoplay = false } = Astro.props;
// Generate a unique ID so multiple galleries don't collide if rendered on the same page.
const galleryId = "gallery-" + Math.random().toString(36).substr(2, 9);
---

<div class="perfect-loop-gallery" id={galleryId} data-autoplay={autoplay ? 'true' : 'false'} tabindex="0" aria-label="Image Gallery. Use left and right arrow keys to navigate.">
  
  {/* Counter (e.g. "3 / 5") */}
  {images.length > 1 && (
    <div class="gallery-counter">
      <span class="current-index">1</span> / <span class="total-count">{images.length}</span>
    </div>
  )}

  {/* Slide Track */}
  <div class="gallery-track" aria-live="polite">
    {images.map((img, index) => (
      <div 
        class={`gallery-slide ${index === 0 ? 'active' : ''}`} 
        data-index={index}
        aria-hidden={index === 0 ? "false" : "true"}
      >
        <img src={img.src} alt={img.alt} loading={index === 0 ? "eager" : "lazy"} />
        {img.title && <div class="gallery-caption">{img.title}</div>}
      </div>
    ))}
    
    {/* Graceful empty state */}
    {images.length === 0 && (
      <div class="gallery-slide active">
        <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#888;">
          No images provided
        </div>
      </div>
    )}
  </div>

  {/* Directional Controls (Hidden if 1 or 0 images) */}
  {images.length > 1 && (
    <>
      <button class="gallery-nav prev-btn" aria-label="Previous Image">
        <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="gallery-nav next-btn" aria-label="Next Image">
        <svg viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg>
      </button>
    </>
  )}

  {/* Bottom UI Controls */}
  {images.length > 1 && (
    <div class="gallery-controls-bar">
      
      {/* Play/Pause Button */}
      <button class="play-pause-btn" aria-label={autoplay ? "Pause autoplay" : "Play autoplay"}>
        {autoplay ? (
          <svg class="icon-pause" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
        ) : (
          <svg class="icon-play" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        )}
      </button>
      
      {/* Dynamic Dot Indicators */}
      <div class="gallery-dots" role="tablist">
        {images.map((_, idx) => (
          <button 
            class={`dot ${idx === 0 ? 'active' : ''}`} 
            role="tab" 
            aria-label={`Go to slide ${idx + 1}`}
            aria-selected={idx === 0 ? "true" : "false"}
            data-index={idx}>
          </button>
        ))}
      </div>
      
    </div>
  )}
</div>

<style>
/* Scoped Styling for the Component (No external dependencies required) */
.perfect-loop-gallery {
  position: relative;
  width: 100%;
  max-width: 1200px; /* Adjust according to layout */
  margin: 0 auto;
  overflow: hidden;
  border-radius: 8px; /* Smooth, modern aesthetic */
  background: #000;
  color: #fff;
  aspect-ratio: 16 / 9; /* Ensures a consistent viewport */
  outline: none; /* Removed default outline, replaced with custom focus */
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
}

.gallery-track {
  position: relative;
  width: 100%;
  height: 100%;
}

/* ALBUM SLIDE TRANSITION LOGIC */
.gallery-slide {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0;
  visibility: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.gallery-slide.active {
  opacity: 1;
  visibility: visible;
  z-index: 3; 
}

.gallery-slide.exiting {
  opacity: 1;
  visibility: visible;
  z-index: 2;
}

/* Directional Animations mapped against data-direction */
.perfect-loop-gallery[data-direction="next"] .gallery-slide.active {
  animation: slideInNext 0.7s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}
.perfect-loop-gallery[data-direction="next"] .gallery-slide.exiting {
  animation: slideOutNext 0.7s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}
.perfect-loop-gallery[data-direction="prev"] .gallery-slide.active {
  animation: slideInPrev 0.7s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}
.perfect-loop-gallery[data-direction="prev"] .gallery-slide.exiting {
  animation: slideOutPrev 0.7s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

@keyframes slideInNext {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}
@keyframes slideOutNext {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); opacity: 0.5; }
}
@keyframes slideInPrev {
  from { transform: translateX(-100%); }
  to { transform: translateX(0); }
}
@keyframes slideOutPrev {
  from { transform: translateX(0); }
  to { transform: translateX(50%); opacity: 0.5; }
}

.gallery-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover; /* Prevents stretching */
}

.gallery-caption {
  position: absolute;
  bottom: 12%;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.5);
  padding: 0.6rem 2rem;
  border-radius: 30px;
  font-size: 0.95rem;
  letter-spacing: 0.05em;
  backdrop-filter: blur(8px);
  text-transform: uppercase;
  min-width: max-content;
}

/* TOP RIGHT COUNTER */
.gallery-counter {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  z-index: 10;
  background: rgba(0, 0, 0, 0.4);
  padding: 0.4rem 1.2rem;
  border-radius: 20px;
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  font-feature-settings: "tnum"; /* Tabular numbers prevent jitter */
  font-variant-numeric: tabular-nums;
  backdrop-filter: blur(4px);
}

/* NAVIGATION BUTTONS */
.gallery-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  width: 3.5rem; height: 3.5rem;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center; justify-content: center;
  transition: background 0.3s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  backdrop-filter: blur(6px);
}

.gallery-nav:hover {
  background: rgba(255, 255, 255, 0.25);
  transform: translateY(-50%) scale(1.05); /* Interactive micro-animation */
}

.gallery-nav svg { width: 1.5rem; height: 1.5rem; fill: transparent; stroke: white; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
.prev-btn { left: 1.5rem; }
.next-btn { right: 1.5rem; }

/* BOTTOM CONTROLS (Dots + Autoplay) */
.gallery-controls-bar {
  position: absolute;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 1.5rem;
  background: rgba(0, 0, 0, 0.4);
  padding: 0.6rem 2rem;
  border-radius: 30px;
  backdrop-filter: blur(6px);
}

.play-pause-btn {
  background: none;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  opacity: 0.6;
  transition: opacity 0.3s, transform 0.3s;
}

.play-pause-btn:hover { opacity: 1; transform: scale(1.1); }
.play-pause-btn svg { width: 1.2rem; height: 1.2rem; fill: white; }

.gallery-dots {
  display: flex;
  gap: 0.8rem;
  align-items: center;
}

.dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: background 0.3s ease, transform 0.3s ease;
}

.dot.active {
  background: white;
  transform: scale(1.3);
}

.dot:hover:not(.active) {
  background: rgba(255, 255, 255, 0.6);
}

/* RESPONSIVE POLISH */
@media (max-width: 768px) {
  .perfect-loop-gallery { aspect-ratio: 4 / 3; border-radius: 0; }
  .gallery-nav { width: 2.5rem; height: 2.5rem; }
  .gallery-nav svg { width: 1.2rem; height: 1.2rem; }
  .prev-btn { left: 0.5rem; }
  .next-btn { right: 0.5rem; }
  .gallery-caption { font-size: 0.8rem; padding: 0.5rem 1rem; width: 80%; text-align: center; }
  .gallery-controls-bar { padding: 0.5rem 1.5rem; bottom: 1rem; }
}

/* ACCESSIBILITY FOCUS DEFAULTS */
.perfect-loop-gallery:focus-visible {
  box-shadow: 0 0 0 4px rgba(209, 184, 148, 0.6);
}
button:focus-visible {
  outline: 2px solid white;
  outline-offset: 3px;
}
</style>

<script>
class PerfectLoopGalleryHandler {
  constructor(element) {
    this.root = element;
    this.slides = Array.from(this.root.querySelectorAll('.gallery-slide'));
    this.dots = Array.from(this.root.querySelectorAll('.dot'));
    this.prevBtn = this.root.querySelector('.prev-btn');
    this.nextBtn = this.root.querySelector('.next-btn');
    this.playPauseBtn = this.root.querySelector('.play-pause-btn');
    this.currentIndexEl = this.root.querySelector('.current-index');
    
    // Core check: 1 image or empty array bypasses all complex logic safely
    if (this.slides.length <= 1) return; 

    this.total = this.slides.length;
    this.currentIndex = 0;
    this.isAutoplaying = this.root.dataset.autoplay === 'true';
    this.intervalId = null;

    this.init();
  }

  init() {
    // 1. Mouse Navigations
    this.prevBtn?.addEventListener('click', () => this.navigate('prev'));
    this.nextBtn?.addEventListener('click', () => this.navigate('next'));
    
    this.dots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        const index = parseInt(e.target.dataset.index, 10);
        this.goTo(index);
      });
    });

    this.playPauseBtn?.addEventListener('click', () => this.toggleAutoplay());

    // 2. Keyboard Navigation (Fires when the gallery is focused natively)
    this.root.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') this.navigate('prev');
      if (e.key === 'ArrowRight') this.navigate('next');
    });

    // 3. Autoplay Initializer
    if (this.isAutoplaying) this.startAutoplay();
  }

  /**
   * PERFECT LOOP ALGORITHM
   * The formula `(currentIndex + direction + total) % total` achieves
   * a flawless cyclic boundary calculation.
   * Ex: Going backward from index 0 -> (0 - 1 + 5) % 5 = 4 (Hits exactly the last image)
   */
  navigate(direction) {
    const step = direction === 'next' ? 1 : -1;
    const nextIndex = (this.currentIndex + step + this.total) % this.total;
    this.goTo(nextIndex, direction);
  }

  goTo(index, direction = null) {
    if (index === this.currentIndex) return; // Ignore redundant requests
    
    // Auto-detect direction if dot indicators are clicked
    if (!direction) {
       direction = index > this.currentIndex ? 'next' : 'prev';
    }
    this.root.setAttribute('data-direction', direction);

    // Clean up any old exiting slides to prevent visual ghosts
    this.slides.forEach(slide => {
      slide.classList.remove('exiting');
      if (!slide.classList.contains('active')) {
         slide.setAttribute('aria-hidden', 'true');
      }
    });

    // Demote current slide to exiting state
    this.slides[this.currentIndex].classList.remove('active');
    this.slides[this.currentIndex].classList.add('exiting');
    this.dots[this.currentIndex]?.classList.remove('active');
    this.dots[this.currentIndex]?.setAttribute('aria-selected', 'false');

    // Upgrade new slide to active state
    this.currentIndex = index;
    this.slides[this.currentIndex].classList.add('active');
    this.slides[this.currentIndex].classList.remove('exiting'); // safe wipe
    this.slides[this.currentIndex].setAttribute('aria-hidden', 'false');
    this.dots[this.currentIndex]?.classList.add('active');
    this.dots[this.currentIndex]?.setAttribute('aria-selected', 'true');
    
    // Refresh Counter Text
    if (this.currentIndexEl) {
      this.currentIndexEl.textContent = String(this.currentIndex + 1);
    }
  }

  startAutoplay() {
    this.pauseAutoplay(); // Clear any existing intervals to prevent acceleration bugs
    this.intervalId = setInterval(() => this.navigate('next'), 3000);
  }

  pauseAutoplay() {
    if (this.intervalId) clearInterval(this.intervalId);
  }

  toggleAutoplay() {
    this.isAutoplaying = !this.isAutoplaying;
    
    // Update SVG and ARIA labels dynamically 
    if (this.isAutoplaying) {
      this.startAutoplay();
      this.playPauseBtn.setAttribute('aria-label', 'Pause autoplay');
      this.playPauseBtn.innerHTML = '<svg class="icon-pause" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';
    } else {
      this.pauseAutoplay();
      this.playPauseBtn.setAttribute('aria-label', 'Play autoplay');
      this.playPauseBtn.innerHTML = '<svg class="icon-play" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
    }
  }
}

// Attach gracefully via Astro's standard event listener hook
// This ensures compatibility even if you are using Astro ViewTransitions!
document.addEventListener('astro:page-load', () => {
  document.querySelectorAll('.perfect-loop-gallery').forEach(el => new PerfectLoopGalleryHandler(el));
});
</script>
