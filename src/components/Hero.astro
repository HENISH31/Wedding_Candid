---
/**
 * Hero.astro — Premium Cinematic Hero
 * Synchronized background and text transitions.
 * Keeps the original splash screen.
 */
---

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Jost:wght@200;300;400&display=swap" rel="stylesheet" />

<!-- ══════════════════════════════════════════
     SPLASH SCREEN  (Preserved from original)
══════════════════════════════════════════ -->
<div id="splash" aria-hidden="true">
  <div class="splash-half splash-top"></div>
  <div class="splash-half splash-bottom"></div>

  <div id="splash-logo">
    <div id="camera-wrap">
      <svg id="camera-draw" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="8"  y="28" width="104" height="72" rx="10" ry="10" fill="none" stroke="#1a1814" stroke-width="3"   class="cam-stroke" style="--len:360"/>
        <rect x="28" y="18" width="16"  height="10" rx="3"  ry="3"  fill="none" stroke="#1a1814" stroke-width="2.5" class="cam-stroke" style="--len:60"/>
        <rect x="50" y="16" width="10"  height="12" rx="2"  ry="2"  fill="none" stroke="#1a1814" stroke-width="2.5" class="cam-stroke" style="--len:48"/>
        <circle cx="60" cy="66" r="22" fill="none" stroke="#1a1814" stroke-width="3"   class="cam-stroke" style="--len:138"/>
        <circle cx="60" cy="66" r="14" fill="none" stroke="#1a1814" stroke-width="2"   class="cam-stroke" style="--len:88"/>
        <circle cx="100" cy="42" r="4" fill="none" stroke="#1a1814" stroke-width="2"   class="cam-stroke" style="--len:25"/>
      </svg>
    </div>
    <div class="splash-wordmark">
      <span class="splash-title">WEDDING CANDY</span>
      <span class="splash-sub">PHOTOGRAPHY</span>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     PREMIUM CINEMATIC HERO
══════════════════════════════════════════ -->
<section id="premium-hero">
  <!-- Background Slider -->
  <div class="hero-bg-container">
    <div class="hero-slide active" style="background-image: url('/homepage/WC_11751.JPG');"></div>
    <div class="hero-slide" style="background-image: url('/homepage/DJI_20241209172706_0093_D_FLYCAPTURE%202.jpg');"></div>
    <div class="hero-slide" style="background-image: url('/homepage/DJI_0639.jpg');"></div>
  </div>

  <!-- Soft Overlay -->
  <div class="hero-overlay"></div>

  <!-- Content -->
  <div class="hero-container">
    <div class="hero-content">
      <h1 class="hero-heading dark-text">
        <span class="static-line">CAPTURING</span>
        <span class="dynamic-wrap">
          <span id="hero-word">HONEST STORIES</span>
        </span>
      </h1>
      <p class="hero-tagline">Legacy in motion</p>
      <div class="hero-line"></div>
    </div>
  </div>

  <!-- Scroll Nudge -->
  <div class="scroll-indicator">
    <span class="scroll-text">Explore</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     STYLES
══════════════════════════════════════════ -->
<style>
  :root {
    --cream: #f8f6f2;
    --gold: #C9A84C;
    --ink: #1a1814;
    --serif: 'Cormorant Garamond', serif;
    --sans: 'Jost', sans-serif;
    --ease-ultra: cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* ── SPLASH (Preserved) ────────────────── */
  #splash {
    position: fixed; inset: 0;
    z-index: 10000;
    background: var(--cream);
    clip-path: circle(150% at 50% 50%);
    transition: clip-path 1.6s cubic-bezier(0.76, 0, 0.24, 1), filter 1.6s ease;
    will-change: clip-path, filter;
  }
  #splash.split {
    clip-path: circle(0% at 50% 50%);
    filter: blur(30px);
    pointer-events: none;
  }
  #splash-logo {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 1.4rem;
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: 2;
  }
  #splash-logo.visible { opacity: 1; }
  #splash-logo.fade-out { opacity: 0; transition-duration: 0.35s; }
  #camera-wrap { position: relative; width: 110px; height: 110px; }
  #camera-draw { position: absolute; inset: 0; width: 100%; height: 100%; overflow: visible; }
  .cam-stroke { stroke-dasharray: var(--len); stroke-dashoffset: var(--len); animation: drawStroke 2.2s cubic-bezier(0.4,0,0.2,1) forwards; }
  @keyframes drawStroke { to { stroke-dashoffset: 0; } }
  .splash-wordmark { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; }
  .splash-title { font-family: var(--sans); font-weight: 300; font-size: 1.05rem; letter-spacing: 0.45em; color: var(--ink); }
  .splash-sub { font-family: var(--sans); font-weight: 200; font-size: 0.58rem; letter-spacing: 0.55em; color: var(--gold); text-transform: uppercase; }

  /* ── PREMIUM HERO ─────────────────────── */
  #premium-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #000;
    overflow: hidden;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-bg-container {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.6s var(--ease-ultra);
    transform: scale(1.05);
    will-change: transform, opacity;
  }

  .hero-slide.active {
    opacity: 1;
    z-index: 2;
    animation: kenBurns 10s linear infinite alternate;
  }

  @keyframes kenBurns {
    0% { transform: scale(1.0); }
    100% { transform: scale(1.05); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 20%, rgba(0,0,0,0.28) 100%);
    z-index: 3;
  }

  .hero-container {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    transition: all 1.2s var(--ease-ultra);
  }

  #premium-hero.in .hero-content {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-heading {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 8.5vw, 8.5rem);
    font-weight: 300;
    line-height: 0.85;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    transition: color 0.6s ease;
  }

  .hero-heading.dark-text {
    color: var(--ink);
  }

  .static-line {
    display: block;
    opacity: 1;
  }

  .dynamic-wrap {
    display: block;
    height: 1.1em;
    overflow: hidden;
    position: relative;
    font-weight: 300;
  }

  .hero-tagline {
    font-family: var(--serif);
    font-size: clamp(0.9rem, 1.5vw, 1.25rem);
    font-style: italic;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.3em;
    opacity: 0;
    transform: translateY(10px);
    transition: all 1s ease 4.2s;
  }

  #premium-hero.in .hero-tagline {
    opacity: 1;
    transform: translateY(0);
  }

  #hero-word {
    display: block;
    white-space: nowrap;
    transition: transform 0.8s var(--ease-ultra), opacity 0.8s ease;
  }

  .hero-line {
    display: none;
  }


  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 5vh;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    z-index: 10;
    opacity: 0;
    transition: opacity 1s ease 1s;
  }

  #premium-hero.in .scroll-indicator {
    opacity: 1;
  }

  .scroll-text {
    font-family: var(--sans);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.5);
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.2);
    position: relative;
    overflow: hidden;
  }

  .scroll-line::after {
    content: '';
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--gold);
    animation: scrollLineMove 2.5s infinite var(--ease-ultra);
  }

  @keyframes scrollLineMove {
    0% { top: -100%; }
    100% { top: 100%; }
  }

  @media (max-width: 768px) {
    .hero-heading { font-size: 3rem; }
  }
</style>

<!-- ══════════════════════════════════════════
     SCRIPTS
══════════════════════════════════════════ -->
<script>
  import { gsap } from 'gsap';

  // Advanced tracking for Astro internal + external navigations
  let sessionSplashExecuted = false;

  function shouldShowSplash() {
    if (sessionSplashExecuted) return false;
    
    try {
      const navEntries = performance.getEntriesByType('navigation');
      if (navEntries.length > 0 && navEntries[0].type === 'reload') {
        return true;
      }
    } catch(e) {}

    if (!sessionStorage.getItem('wc_hero_splash_played')) return true;

    return false;
  }

  function initPremiumHero() {
    const hero = document.getElementById('premium-hero');
    const splash = document.getElementById('splash');
    const splashLogo = document.getElementById('splash-logo');
    const wordEl = document.getElementById('hero-word');
    const slides = document.querySelectorAll('.hero-slide');
    
    if (!hero) return;

    // ── Preload Images ──────────────────────────
    const images = [
      '/homepage/WC_11751.JPG',
      '/homepage/DJI_20241209172706_0093_D_FLYCAPTURE%202.jpg',
      '/homepage/DJI_0639.jpg'
    ];
    images.forEach(src => {
      const img = new Image();
      img.src = src;
    });

    // ── Splash Screen Logic ─────────────────────
    const isFirstLoad = shouldShowSplash();

    if (splash && splashLogo && isFirstLoad) {
      sessionSplashExecuted = true;
      sessionStorage.setItem('wc_hero_splash_played', 'true');
      setTimeout(() => splashLogo.classList.add('visible'),  300);
      setTimeout(() => splashLogo.classList.add('fade-out'), 3200);
      setTimeout(() => {
        splash.classList.add('split');
        hero.classList.add('in'); // REVEAL HERO IMMEDIATELY AS SPLASH SPLITS
      }, 3600);
      setTimeout(() => { 
        splash.style.display = 'none'; 
      }, 4800);
    } else {
      // Skip splash completely on internal navigation
      if (splash) splash.style.display = 'none';
      hero.classList.add('in');
    }

    // ── Rotation Logic ──────────────────────────
    const phrases = ['HONEST STORIES', 'CINEMATIC MOMENTS', 'PURE EMOTIONS'];
    let currentIdx = 0;

    const changeSlide = () => {
      const nextIdx = (currentIdx + 1) % phrases.length;

      // 1. Transition Word out
      gsap.to(wordEl, {
        y: -30,
        opacity: 0,
        duration: 0.4,
        ease: 'power3.in',
        onComplete: () => {
          // Word comes in
          wordEl.textContent = phrases[nextIdx];
          gsap.fromTo(wordEl, { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6, ease: 'power3.out' });

          // 2. Transition Background at the exact same time
          slides[currentIdx].classList.remove('active');
          slides[nextIdx].classList.add('active');

          // 3. Toggle Dark Text for Specific Slide simultaneously
          const heading = document.querySelector('.hero-heading');
          if (heading) {
            if (nextIdx === 0) {
              heading.classList.add('dark-text');
            } else {
              heading.classList.remove('dark-text');
            }
          }

          currentIdx = nextIdx;
        }
      });
    };

    // Start interval after splash
    let interval;
    const intervalDelay = isFirstLoad ? 5000 : 1000;
    
    setTimeout(() => {
      interval = setInterval(changeSlide, 3000); 
    }, intervalDelay);

    // Cleanup
    document.addEventListener('astro:before-preparation', () => {
      clearInterval(interval);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initPremiumHero);
</script>
