---
/**
 * Custom Interactive Glass Lens Cursor
 */
---
<!-- Cursor Structure -->
<div id="custom-cursor" class="pointer-events-none fixed top-0 left-0 z-[9999] opacity-0 transition-opacity duration-300 hidden md:block">
  <div id="glass-lens" class="absolute left-0 top-0 w-8 h-8 rounded-full border border-white/40 shadow-[0_4px_20px_rgba(0,0,0,0.1)] flex items-center justify-center font-sans text-[8px] font-medium tracking-widest text-white text-shadow-sm" style="will-change: transform; transform: translate3d(var(--x, 0px), var(--y, 0px), 0) translate(-50%, -50%); transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1), height 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease;"></div>
  <div id="cursor-dot" class="absolute left-0 top-0 w-1 h-1 bg-white rounded-full transition-opacity duration-300 shadow-[0_0_4px_rgba(255,255,255,0.8)]" style="will-change: transform; transform: translate3d(var(--dx, 0px), var(--dy, 0px), 0) translate(-50%, -50%);"></div>
</div>

<style>
  /* Only hide default cursor on desktop */
  @media (hover: hover) and (pointer: fine) {
    html { cursor: none !important; }
    a, button, input, .canvas-item, .g-cell { cursor: none !important; }
  }
  
  .text-shadow-sm {
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
  }
</style>

<script is:inline>
  function initCursor() {
    // Only run on desktop
    if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;

    const cursor = document.getElementById('custom-cursor');
    const dot = document.getElementById('cursor-dot');
    const lens = document.getElementById('glass-lens');
    if (!cursor) return;
    
    cursor.style.opacity = '1';

    let mouseX = window.innerWidth / 2;
    let mouseY = window.innerHeight / 2;

    let lensX = mouseX;
    let lensY = mouseY;
    let dotX = mouseX;
    let dotY = mouseY;

    const onMouseMove = (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    };
    window.addEventListener('mousemove', onMouseMove, { passive: true });

    const render = () => {
      // Faster, snappier multipliers (0.12 -> 0.22 for lens, 0.4 -> 0.6 for dot)
      lensX += (mouseX - lensX) * 0.22;
      lensY += (mouseY - lensY) * 0.22;
      
      dotX += (mouseX - dotX) * 0.6;
      dotY += (mouseY - dotY) * 0.6;
      
      // Using CSS Variables for GPU-accelerated updates without direct DOM manipulation thrash
      lens.style.setProperty('--x', `${lensX}px`);
      lens.style.setProperty('--y', `${lensY}px`);
      dot.style.setProperty('--dx', `${dotX}px`);
      dot.style.setProperty('--dy', `${dotY}px`);
      
      requestAnimationFrame(render);
    };
    requestAnimationFrame(render);

    // Hover logic for links and buttons
    const attachHoverEvents = () => {
      document.querySelectorAll('a, button, .btn-dark, .btn-ghost, .curtain-reveal, .canvas-item, .g-cell').forEach(el => {
        // Prevent duplicate listeners
        if (el.hasAttribute('data-cursor-bound')) return;
        el.setAttribute('data-cursor-bound', 'true');

        el.addEventListener('mouseenter', () => {
          dot.style.opacity = '0';
          
          lens.style.width = '72px';
          lens.style.height = '72px';
          lens.style.width = '72px';
          lens.style.height = '72px';
          // Keep it fully transparent on hover, just glow the border
          lens.style.borderColor = 'rgba(255,255,255,0.6)';
          lens.style.background = 'transparent';
          
          // Determine label based on element context
          if (el.classList.contains('curtain-reveal')) {
             lens.innerHTML = 'VIEW';
          } else if (el.closest('.canvas-item') || el.closest('.g-cell')) {
             lens.innerHTML = 'VIEW';
          } else if (el.closest('#drag-viewport')) {
             lens.innerHTML = 'DRAG'; 
          } else {
             // Leave empty for standard links, or put 'CLICK'
             lens.innerHTML = ''; 
          }
        });
        
        el.addEventListener('mouseleave', () => {
          dot.style.opacity = '1';
          
          lens.style.width = '32px';
          lens.style.height = '32px';
          lens.style.width = '32px';
          lens.style.height = '32px';
          // Ensure it stays transparent
          lens.style.borderColor = 'rgba(255,255,255,0.3)';
          lens.style.background = 'transparent';
          lens.innerHTML = '';
        });
      });
      
      // Specifically for the infinite canvas background drag
      const dragViewport = document.getElementById('drag-viewport');
      if (dragViewport && !dragViewport.hasAttribute('data-cursor-bound')) {
        dragViewport.setAttribute('data-cursor-bound', 'true');
        
        dragViewport.addEventListener('mouseenter', () => {
          // Only show 'DRAG' if we aren't hovering a specific photo
          lens.innerHTML = 'DRAG';
        });
        dragViewport.addEventListener('mousedown', () => {
          lens.style.transform = `translate(-50%, -50%) translate(${lensX}px, ${lensY}px) scale(0.85)`;
        });
        window.addEventListener('mouseup', () => {
          // No blur needed
        });
      }
    };

    attachHoverEvents();
    
    // Reattach when DOM changes
    const observer = new MutationObserver(attachHoverEvents);
    observer.observe(document.body, { childList: true, subtree: true });
  }

  document.addEventListener('astro:page-load', initCursor);
</script>
