---
/**
 * Custom Interactive Glass Lens Cursor
 */
---
<!-- Cursor Structure -->
<div id="custom-cursor" class="pointer-events-none fixed top-0 left-0 z-[9999] opacity-0 transition-opacity duration-300 hidden md:block">
  <div id="glass-lens" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 rounded-full border border-white/20 shadow-[inset_0_0_10px_rgba(255,255,255,0.1),0_4px_20px_rgba(0,0,0,0.15)] transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] flex items-center justify-center font-sans text-[8px] font-medium tracking-widest text-white text-shadow-sm" style="backdrop-filter: blur(4px) brightness(1.1) saturate(1.2); -webkit-backdrop-filter: blur(4px) brightness(1.1) saturate(1.2); will-change: width, height, transform;"></div>
  <div id="cursor-dot" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-1 h-1 bg-white rounded-full transition-opacity duration-300 shadow-[0_0_4px_rgba(255,255,255,0.8)]"></div>
</div>

<style>
  /* Only hide default cursor on desktop */
  @media (hover: hover) and (pointer: fine) {
    html { cursor: none !important; }
    a, button, input, .canvas-item, .g-cell { cursor: none !important; }
  }
  
  .text-shadow-sm {
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
  }
</style>

<script is:inline>
  function initCursor() {
    // Only run on desktop
    if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;

    const cursor = document.getElementById('custom-cursor');
    const dot = document.getElementById('cursor-dot');
    const lens = document.getElementById('glass-lens');
    if (!cursor) return;
    
    cursor.style.opacity = '1';

    let mouseX = window.innerWidth / 2;
    let mouseY = window.innerHeight / 2;
    // Faster snapping for the dot, smoother trailing for the heavy glass lens
    let lensX = mouseX;
    let lensY = mouseY;
    let dotX = mouseX;
    let dotY = mouseY;

    window.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    const render = () => {
      // The lens has an incredibly smooth, heavy liquid drag feel
      lensX += (mouseX - lensX) * 0.12;
      lensY += (mouseY - lensY) * 0.12;
      
      // The dot is extremely snapping and responsive
      dotX += (mouseX - dotX) * 0.4;
      dotY += (mouseY - dotY) * 0.4;
      
      lens.style.transform = `translate(-50%, -50%) translate(${lensX}px, ${lensY}px)`;
      dot.style.transform = `translate(-50%, -50%) translate(${dotX}px, ${dotY}px)`;
      
      requestAnimationFrame(render);
    };
    render();

    // Hover logic for links and buttons
    const attachHoverEvents = () => {
      document.querySelectorAll('a, button, .btn-dark, .btn-ghost, .curtain-reveal, .canvas-item, .g-cell').forEach(el => {
        // Prevent duplicate listeners
        if (el.hasAttribute('data-cursor-bound')) return;
        el.setAttribute('data-cursor-bound', 'true');

        el.addEventListener('mouseenter', () => {
          dot.style.opacity = '0';
          
          lens.style.width = '72px';
          lens.style.height = '72px';
          // Deepen the refraction and blur drastically on hover
          lens.style.backdropFilter = 'blur(10px) brightness(1.15) saturate(1.4)';
          lens.style.webkitBackdropFilter = 'blur(10px) brightness(1.15) saturate(1.4)';
          lens.style.borderColor = 'rgba(255,255,255,0.4)';
          lens.style.background = 'rgba(255,255,255,0.08)';
          
          // Determine label based on element context
          if (el.classList.contains('curtain-reveal')) {
             lens.innerHTML = 'VIEW';
          } else if (el.closest('.canvas-item') || el.closest('.g-cell')) {
             lens.innerHTML = 'VIEW';
          } else if (el.closest('#drag-viewport')) {
             lens.innerHTML = 'DRAG'; 
          } else {
             // Leave empty for standard links, or put 'CLICK'
             lens.innerHTML = ''; 
          }
        });
        
        el.addEventListener('mouseleave', () => {
          dot.style.opacity = '1';
          
          lens.style.width = '32px';
          lens.style.height = '32px';
          // Return to subtle idle glass
          lens.style.backdropFilter = 'blur(4px) brightness(1.1) saturate(1.2)';
          lens.style.webkitBackdropFilter = 'blur(4px) brightness(1.1) saturate(1.2)';
          lens.style.borderColor = 'rgba(255,255,255,0.2)';
          lens.style.background = 'transparent';
          lens.innerHTML = '';
        });
      });
      
      // Specifically for the infinite canvas background drag
      const dragViewport = document.getElementById('drag-viewport');
      if (dragViewport && !dragViewport.hasAttribute('data-cursor-bound')) {
        dragViewport.setAttribute('data-cursor-bound', 'true');
        
        dragViewport.addEventListener('mouseenter', () => {
          // Only show 'DRAG' if we aren't hovering a specific photo
          lens.innerHTML = 'DRAG';
        });
        dragViewport.addEventListener('mousedown', () => {
          lens.style.transform = `translate(-50%, -50%) translate(${lensX}px, ${lensY}px) scale(0.85)`;
          lens.style.backdropFilter = 'blur(16px) brightness(1.1) saturate(1.5)';
          lens.style.webkitBackdropFilter = 'blur(16px) brightness(1.1) saturate(1.5)';
        });
        window.addEventListener('mouseup', () => {
          lens.style.backdropFilter = 'blur(4px) brightness(1.1) saturate(1.2)';
          lens.style.webkitBackdropFilter = 'blur(4px) brightness(1.1) saturate(1.2)';
        });
      }
    };

    attachHoverEvents();
    
    // Reattach when DOM changes
    const observer = new MutationObserver(attachHoverEvents);
    observer.observe(document.body, { childList: true, subtree: true });
  }

  document.addEventListener('astro:page-load', initCursor);
</script>
