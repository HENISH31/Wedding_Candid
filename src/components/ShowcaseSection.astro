---
/**
 * ShowcaseSection.astro
 * Parallax image + Text showcase.
 */
---
<section class="showcase-section relative min-h-screen bg-neutral-50 px-6 md:px-20 py-40 overflow-hidden flex flex-col md:flex-row items-center gap-24">
  <!-- Right Side: Vertical Image (Portrait) -->
  <div class="relative w-full md:w-5/12 ml-auto" id="showcase-image-container">
    <div class="relative overflow-hidden aspect-[3/4] rounded-lg shadow-2xl skew-y-2" id="showcase-img-wrapper">
      <img 
        src="/candid/SSP01330.JPG" 
        alt="Photography Showcase" 
        class="w-full h-full object-cover scale-150 transition-transform duration-[0.1s] ease-linear"
        id="parallax-image"
      />
    </div>
    
    <!-- Decorative background layer -->
    <div class="absolute -z-10 -bottom-12 -right-12 w-full h-full border-2 border-accent opacity-20 rounded-lg"></div>
    <div class="absolute -z-20 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[110%] h-[110%] bg-neutral-100 blur-[80px] opacity-40"></div>
  </div>

  <!-- Left Side: Text Content -->
  <div class="w-full md:w-5/12 flex flex-col items-start space-y-12 order-first md:order-last" id="showcase-text">
    <div class="space-y-4">
      <span class="text-xs tracking-[0.4em] text-accent font-sans uppercase font-medium showcase-reveal">A VISION FOR THE TIMELESS</span>
      <h2 class="text-5xl md:text-7xl font-serif text-neutral-900 leading-tight showcase-reveal">
        BEYOND THE <br /> <span class="italic">SHUTTER CLICK</span>
      </h2>
    </div>

    <div class="max-w-md space-y-8 showcase-reveal">
      <p class="text-neutral-900/70 font-sans text-xl leading-relaxed">
        My philosophy is simple: document the human experience exactly as it unfolds. No forced poses, no plastic smiles—only the raw, cinematic beauty of real life.
      </p>
      
      <p class="text-neutral-900/60 font-sans text-base leading-relaxed italic">
        "There is a quiet dignity in the mundane. A story in the shadows."
      </p>
    </div>

    <div class="showcase-reveal pt-4">
      <button class="px-8 py-4 border border-neutral-900 text-neutral-900 font-sans text-xs tracking-[0.2em] uppercase hover:bg-neutral-900 hover:text-white transition-all duration-500 rounded-full">
        Read the Manifesto
      </button>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initShowcaseSection() {
    gsap.registerPlugin(ScrollTrigger);

    // Parallax Effect
    gsap.to('#parallax-image', {
      yPercent: -20,
      ease: 'none',
      scrollTrigger: {
        trigger: '#showcase-img-wrapper',
        start: 'top bottom',
        end: 'bottom top',
        scrub: true
      }
    });

    // Reveal Animation
    const reveals = document.querySelectorAll('.showcase-reveal');
    reveals.forEach((reveal, idx) => {
      gsap.from(reveal, {
        x: -50,
        opacity: 0,
        duration: 1.5,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: reveal,
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initShowcaseSection);
</script>
