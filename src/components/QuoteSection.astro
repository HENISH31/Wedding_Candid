---
/**
 * QuoteSection.astro
 * Centered testimonial with fade-in and blur-to-clear effect.
 */
---
<section class="testimonial-section bg-neutral-900 px-6 md:px-20 py-40 overflow-hidden flex flex-col items-center justify-center text-center">
  <div class="max-w-4xl space-y-12">
    <div class="flex justify-center mb-8 relative opacity-30 select-none">
      <span class="text-[12rem] font-serif font-black absolute -top-32 left-1/2 -translate-x-1/2 -translate-y-1/2 text-white italic scale-y-[-1] leading-none pointer-events-none">"</span>
    </div>
    
    <p class="text-3xl md:text-5xl font-serif text-white/90 leading-tight italic tracking-tight testimonial-quote opacity-0 blur-[20px]">
      "Photography is the only way I know to stop time without asking it to stay."
    </p>

    <div class="space-y-2 pt-8 testimonial-author opacity-0 flex flex-col items-center">
      <div class="w-12 h-px bg-accent mb-4 scale-x-0 origin-center transition-transform duration-1000 group-hover:scale-x-100"></div>
      <span class="text-xs tracking-[0.4em] text-accent font-sans uppercase font-medium">Bestselling Author</span>
      <h3 class="text-lg font-serif text-white/60 italic lowercase">Wedding Candid</h3>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initQuoteSection() {
    gsap.registerPlugin(ScrollTrigger);

    const quote = document.querySelector('.testimonial-quote');
    const author = document.querySelector('.testimonial-author');

    if (quote) {
      gsap.to(quote, {
        opacity: 1,
        filter: 'blur(0px)',
        duration: 3,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: quote,
          start: 'top 80%',
        }
      });
    }

    if (author) {
      gsap.to(author, {
        opacity: 1,
        y: 0,
        duration: 1.5,
        delay: 0.5,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: author,
          start: 'top 85%',
        }
      });

      const line = author.querySelector('.w-12');
      if (line) {
        gsap.to(line, {
          scaleX: 1,
          duration: 2,
          ease: 'expo.out',
          scrollTrigger: {
            trigger: author,
            start: 'top 85%',
          }
        });
      }
    }
  }

  document.addEventListener('astro:page-load', initQuoteSection);
</script>
