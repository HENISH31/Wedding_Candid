---
/**
 * Preloader.astro
 * Minimal typography reveal.
 */
---
<div id="about-preloader" class="fixed inset-0 z-[10000] bg-neutral-50 flex items-center justify-center overflow-hidden pointer-events-auto transition-transform duration-[1.5s] ease-in-out">
  <div class="preloader-content flex flex-col items-center relative">
    <!-- Camera Logo Branding -->
    <div class="relative w-24 md:w-32 mb-8 overflow-hidden">
      <img src="/camera-logo.png" alt="Photography Logo" class="w-full h-auto opacity-0 translate-y-10" id="preloader-logo" />
      <div class="absolute inset-x-0 bottom-0 h-px bg-accent/20 scale-x-0 origin-center" id="preloader-line"></div>
    </div>
    
    <!-- Progress bar -->
    <div class="w-20 h-px bg-neutral-200 overflow-hidden rounded-full">
      <div class="h-full bg-accent w-0 transition-all duration-[2s] ease-in-out" id="preloader-bar"></div>
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const preloader = document.getElementById('about-preloader');
  const logo = document.getElementById('preloader-logo');
  const line = document.getElementById('preloader-line');
  const bar = document.getElementById('preloader-bar');

  if (preloader && logo && line && bar) {
    const tl = gsap.timeline();

    tl.to(bar, { width: '100%', duration: 1.5, ease: 'power2.inOut' })
      .to(logo, { 
        opacity: 1, 
        y: 0, 
        duration: 1.5, 
        ease: 'power4.out' 
      }, "-=0.5")
      .to(line, { scaleX: 1, duration: 1, ease: 'expo.out' }, "-=1")
      .to(logo, { opacity: 0, y: -10, duration: 0.8, ease: 'power2.in' }, "+=0.3")
      .to(preloader, { yPercent: -100, duration: 1.5, ease: 'expo.inOut', onComplete: () => {
        document.body.classList.remove('overflow-hidden');
      }});

    // Lock scroll during preloader
    document.body.classList.add('overflow-hidden');
  }
</script>
