---
/**
 * ContactCard.astro
 * Centered accent card for the intro.
 */
---
<div class="relative -mt-32 md:-mt-48 z-20 px-6 md:px-0 flex justify-center">
  <div class="w-full max-w-4xl bg-[#2f7d57] text-white p-12 md:p-20 rounded-2xl shadow-2xl overflow-hidden opacity-0 translate-y-20 scale-95" id="contact-intro-card">
    <div class="relative z-10 flex flex-col items-center text-center space-y-10">
      <div class="space-y-4">
        <span class="text-xs tracking-[0.4em] uppercase font-sans font-medium text-white/60">YOUR SEARCH ENDS HERE</span>
        <h2 class="text-5xl md:text-7xl font-serif leading-tight">LET'S CHAT</h2>
      </div>

      <div class="max-w-2xl space-y-8">
        <p class="text-white/80 font-sans text-lg md:text-xl leading-relaxed tracking-tight">
          We don't take a limited number of commissions per year to ensure each story gets the depth and focus it deserves. Tell us your story, and let's create something timeless together.
        </p>

        <div class="w-12 h-px bg-white/20 mx-auto"></div>

        <div class="flex flex-col md:flex-row items-center justify-center gap-10 md:gap-20">
          <div class="space-y-2">
            <span class="text-[10px] tracking-[0.4em] uppercase font-sans text-white/40">EMAIL</span>
            <a href="mailto:hello@psphotography.com" class="block font-serif text-2xl md:text-3xl italic tracking-tighter hover:text-white/60 transition-colors">hello@psphotography.com</a>
          </div>
          <div class="space-y-2">
            <span class="text-[10px] tracking-[0.4em] uppercase font-sans text-white/40">PHONE</span>
            <a href="tel:+1234567890" class="block font-serif text-2xl md:text-3xl italic tracking-tighter hover:text-white/60 transition-colors">+1 (234) 567-890</a>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Decorative Circle in background -->
    <div class="absolute -top-32 -right-32 w-120 h-120 rounded-full border border-white/5 pointer-events-none"></div>
    <div class="absolute -bottom-32 -left-32 w-120 h-120 rounded-full border border-white/5 pointer-events-none"></div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  function initContactCard() {
    gsap.to('#contact-intro-card', {
      opacity: 1,
      y: 0,
      scale: 1,
      duration: 2,
      ease: 'expo.out',
      scrollTrigger: {
        trigger: '#contact-intro-card',
        start: 'top bottom-=100',
      }
    });
  }

  document.addEventListener('astro:page-load', initContactCard);
</script>
