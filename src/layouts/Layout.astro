---
import { ViewTransitions } from "astro:transitions";
import Cursor from "../components/Cursor.astro";
import Navbar from "../components/Navbar.astro";
const { hideGlobalPreloader = false, navTheme = "light" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/camera-logo.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wedding Candid | Editorial & Wedding Portfolio</title>
  <meta name="description" content="Modern, premium photography portfolio specializing in emotional storytelling and timeless imagery.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <ViewTransitions />
</head>

<body class={hideGlobalPreloader ? "" : "preloader-active"} data-nav-theme={navTheme}>
  <!-- Preloader -->
  { !hideGlobalPreloader && (
    <div id="preloader">
      <div class="preloader-content flex flex-col items-center">
        <!-- New Camera Logo Reveal -->
        <div class="logo-container mb-8 relative">
          <img src="/camera-logo.png" alt="Photography Logo" class="preloader-logo-img w-24 md:w-32 h-auto" />
        </div>
        
        <svg width="400" height="60" viewBox="0 0 400 60" class="preloader-drawn-text">
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" font-family="'Outfit', sans-serif" font-size="0.8rem" letter-spacing="0.6em">WEDDING CANDID</text>
        </svg>
      </div>
    </div>
  )}

  <div id="app">
    <!-- Navbar -->
    <Navbar />
    
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        // ── Global Curtain Reveal Observer ────────────────
        const curtainObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              setTimeout(() => entry.target.classList.add('in'), 150);
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });

        document.querySelectorAll('.curtain-reveal').forEach(el => {
          curtainObserver.observe(el);
        });
      });
    </script>

    <!-- Main Content -->
    <main id="main-content">
      <slot />
    </main>

    <footer class="stagger-reveal">
      <div class="footer-grid">
        <div class="footer-logo-box">
          <img src="/wc logo-3.png" alt="WC Footer Logo" style="height: 180px; width: auto; object-fit: contain; margin-bottom: 2rem;">
          <p class="footer-tagline">
            Dedicated to the quiet moments, the unspoken glances, and the light that defines us. Minimalist luxury photography for those who value authenticity.
          </p>
        </div>
        <div class="footer-col">
          <h4>Photography</h4>
          <ul class="footer-links">
            <li><a href="/photography/wedding">Wedding</a></li>
            <li><a href="/photography/pre-wedding">Pre-Wedding</a></li>
            <li><a href="/photography/bw">B/W Noir</a></li>
            <li><a href="/photography/events">Events</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/portfolio">Quick Portfolio</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/testimonials">Testimonials</a></li>
            <li><a href="/booking">Enquire</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; 2024 WEDDING CANDID. ALL RIGHTS RESERVED.
      </div>
    </footer>
    
    <!-- Custom Interactive Cursor -->
    <Cursor />
  </div>
  <style is:global>
    :root {
      --luxury-ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Selection color */
    ::selection {
      background: #d1b894;
      color: white;
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #f8f6f2; }
    ::-webkit-scrollbar-thumb { background: #d1b894; border-radius: 10px; }
  </style>

  <script src="/global.js" type="module"></script>
  <script>
    import Lenis from '@studio-freight/lenis'
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'

    gsap.registerPlugin(ScrollTrigger)

    const lenis = new Lenis()

    lenis.on('scroll', ScrollTrigger.update)

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000)
    })

    gsap.ticker.lagSmoothing(0)

    // REFRESH ENTIRE PAGE SCROLL LOGIC ON EVERY NAVIGATION
    document.addEventListener('astro:after-swap', () => {
      window.scrollTo(0, 0);
      lenis.scrollTo(0, { immediate: true });
      ScrollTrigger.refresh(true);
    });
    document.addEventListener('astro:page-load', () => {
      ScrollTrigger.refresh(true);
    });
  </script>
</body>
</html>
