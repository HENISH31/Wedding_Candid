---
import { ViewTransitions } from "astro:transitions";
const { hideGlobalPreloader = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/vite.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wedding Candid | Editorial & Wedding Portfolio</title>
  <meta name="description" content="Modern, premium photography portfolio specializing in emotional storytelling and timeless imagery.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <ViewTransitions />
</head>

<body class={hideGlobalPreloader ? "" : "preloader-active"}>
  <!-- Preloader -->
  { !hideGlobalPreloader && (
    <div id="preloader">
      <div class="preloader-content flex flex-col items-center">
        <!-- New Camera Logo Reveal -->
        <div class="logo-container mb-8 relative">
          <img src="/camera-logo.png" alt="Photography Logo" class="preloader-logo-img w-24 md:w-32 h-auto" />
        </div>
        
        <svg width="400" height="60" viewBox="0 0 400 60" class="preloader-drawn-text">
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" font-family="'Outfit', sans-serif" font-size="0.8rem" letter-spacing="0.6em">WEDDING CANDID</text>
        </svg>
      </div>
    </div>
  )}

  <div id="app">
    <!-- Navbar -->
    <nav id="navbar" class="fixed top-0 left-0 w-full z-[1000] px-6 md:px-12 py-8 transition-all duration-700 ease-luxury">
      <div class="max-w-7xl mx-auto flex items-center justify-between relative">
        
        <!-- Left Links -->
        <ul class="hidden md:flex items-center gap-10" id="nav-links-left">
          <li><a href="/"         class="nav-link text-[10px] tracking-[0.3em] uppercase font-sans font-medium transition-all duration-300">Home</a></li>
          <li><a href="/portfolio" class="nav-link text-[10px] tracking-[0.3em] uppercase font-sans font-medium transition-all duration-300">Portfolio</a></li>
        </ul>

        <!-- Center Logo -->
        <div class="absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2">
          <a href="/">
            <img src="/wc logo-3.png" alt="WC Logo" class="h-16 md:h-24 w-auto object-contain hover:scale-110 transition-transform duration-500" />
          </a>
        </div>

        <!-- Right Links -->
        <ul class="hidden md:flex items-center gap-10" id="nav-links-right">
          <li><a href="/gallery3d" class="nav-link text-[10px] tracking-[0.3em] uppercase font-sans font-medium transition-all duration-300">Gallery</a></li>
          <li><a href="/about"     class="nav-link text-[10px] tracking-[0.3em] uppercase font-sans font-medium transition-all duration-300">About</a></li>
          <li><a href="/booking"   class="nav-link text-[10px] tracking-[0.3em] uppercase font-sans font-medium transition-all duration-300">Contact</a></li>
        </ul>

        <!-- Mobile Toggle (Handled by JS) -->
        <div class="md:hidden ml-auto">
          <button id="mobile-menu-toggle" class="flex flex-col gap-1.5 p-2 z-[1100] relative">
            <span class="w-6 h-px bg-neutral-900 transition-transform duration-500" id="burger-top"></span>
            <span class="w-4 h-px bg-neutral-900 ml-auto transition-transform duration-500" id="burger-bottom"></span>
          </button>
        </div>

        <!-- Mobile Menu Overlay -->
        <div id="mobile-menu" class="fixed inset-0 bg-neutral-50 z-[1050] translate-x-full transition-transform duration-700 ease-luxury md:hidden flex flex-col items-center justify-center gap-8">
          <a href="/" class="text-3xl font-serif text-neutral-900">Home</a>
          <a href="/portfolio" class="text-3xl font-serif text-neutral-900">Portfolio</a>
          <a href="/gallery3d" class="text-3xl font-serif text-neutral-900">Gallery</a>
          <a href="/about" class="text-3xl font-serif text-neutral-900">About</a>
          <a href="/booking" class="text-3xl font-serif text-neutral-900">Contact</a>
        </div>
      </div>
    </nav>
    
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        // ── Mobile menu ─────────────────────────────────
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        const burgerTop = document.getElementById('burger-top');
        const burgerBottom = document.getElementById('burger-bottom');
        let isOpen = false;

        if (toggle && menu) {
          toggle.addEventListener('click', () => {
            isOpen = !isOpen;
            if (isOpen) {
              menu.style.transform = 'translateX(0)';
              burgerTop.style.transform = 'rotate(45deg) translateY(5px)';
              burgerBottom.style.transform = 'rotate(-45deg) translateY(-5px) scaleX(1.5)';
              document.body.style.overflow = 'hidden';
            } else {
              menu.style.transform = 'translateX(100%)';
              burgerTop.style.transform = 'none';
              burgerBottom.style.transform = 'none';
              document.body.style.overflow = '';
            }
          });
          menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
              isOpen = false;
              menu.style.transform = 'translateX(100%)';
              burgerTop.style.transform = 'none';
              burgerBottom.style.transform = 'none';
              document.body.style.overflow = '';
            });
          });
        }

        // ── Nav link blur-sibling effect ─────────────────
        const allNavLinks = document.querySelectorAll('.nav-link');

        allNavLinks.forEach(link => {
          link.addEventListener('mouseenter', () => {
            allNavLinks.forEach(other => {
              if (other !== link) {
                other.classList.add('nav-blurred');
              } else {
                other.classList.add('nav-focused');
              }
            });
          });

          link.addEventListener('mouseleave', () => {
            allNavLinks.forEach(other => {
              other.classList.remove('nav-blurred', 'nav-focused');
            });
          });

          // Keep active page link always highlighted
          if (link.href === window.location.href ||
              (link.getAttribute('href') !== '/' && window.location.pathname.startsWith(link.getAttribute('href')))) {
            link.classList.add('nav-active');
          }
        });
      });
    </script>

    <!-- Main Content -->
    <main id="main-content">
      <slot />
    </main>

    <footer class="stagger-reveal">
      <div class="footer-grid">
        <div class="footer-logo-box">
          <img src="/wc logo-3.png" alt="WC Footer Logo" style="height: 100px; width: auto; object-fit: contain; margin-bottom: 1.5rem;">
          <p class="footer-tagline">
            Dedicated to the quiet moments, the unspoken glances, and the light that defines us. Minimalist luxury photography for those who value authenticity.
          </p>
        </div>
        <div class="footer-col">
          <h4>Quick Links</h4>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/portfolio">Portfolio</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/booking">Booking</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; 2024 WEDDING CANDID. ALL RIGHTS RESERVED.
      </div>
    </footer>
  </div>
  <style is:global>
    :root {
      --luxury-ease: cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    /* ── Nav link base state ─────────────────────────── */
    .nav-link {
      color: rgba(26, 26, 26, 0.7);
      position: relative;
      filter: blur(0px);
      opacity: 1;
      transition: color 0.35s ease, filter 0.35s ease, opacity 0.35s ease;
    }

    /* Underline indicator using ::after */
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 1px;
      background: #C9A84C;
      transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* Focused (hovered) link */
    .nav-link.nav-focused {
      color: #1a1814;
      opacity: 1;
      filter: blur(0px);
    }
    .nav-link.nav-focused::after { width: 100%; }

    /* Blurred (sibling) links */
    .nav-link.nav-blurred {
      opacity: 0.25;
      filter: blur(2.5px);
      color: rgba(26, 26, 26, 0.2);
    }

    /* Active page link (current route) */
    .nav-link.nav-active {
      color: #1a1814;
    }
    .nav-link.nav-active::after { width: 100%; background: #C9A84C; }

    /* When scrolled — dark theme overrides */
    #navbar.scrolled .nav-link {
      color: rgba(26, 26, 26, 0.75);
    }
    #navbar.scrolled .nav-link.nav-focused {
      color: #1a1814;
    }
    #navbar.scrolled .nav-link.nav-blurred {
      color: rgba(26, 26, 26, 0.3);
    }
    #navbar.scrolled .nav-link.nav-active {
      color: #1a1814;
    }

    #navbar.scrolled {
      background-color: rgba(248, 246, 242, 0.98);
      backdrop-filter: blur(20px);
      padding-top: 1rem;
      padding-bottom: 1rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
      border-bottom: 1px solid rgba(26, 26, 26, 0.05);
      z-index: 2000;
    }

    /* Default links */
    #navbar a {
      color: rgba(26, 26, 26, 0.85);
      transition: color 0.4s ease;
    }
    #navbar a:hover { color: #C9A84C; }

    /* Scrolled links */
    #navbar.scrolled a {
      color: rgba(26, 26, 26, 0.85);
    }
    #navbar.scrolled a:hover { color: #C9A84C; }

    #navbar.scrolled img {
      height: 3.5rem;
    }

    /* Selection color */
    ::selection {
      background: #d1b894; /* accent */
      color: white;
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar {
      width: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #f8f6f2;
    }
    ::-webkit-scrollbar-thumb {
      background: #d1b894;
      border-radius: 10px;
    }
  </style>

  <script src="/global.js" type="module"></script>
  <script>
    import Lenis from '@studio-freight/lenis'
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'

    gsap.registerPlugin(ScrollTrigger)

    const lenis = new Lenis()

    lenis.on('scroll', ScrollTrigger.update)

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000)
    })

    gsap.ticker.lagSmoothing(0)

    // REFRESH ENTIRE PAGE SCROLL LOGIC ON EVERY NAVIGATION
    document.addEventListener('astro:after-swap', () => {
      ScrollTrigger.refresh(true);
    });
    document.addEventListener('astro:page-load', () => {
      ScrollTrigger.refresh(true);
    });
  </script>
</body>
</html>
