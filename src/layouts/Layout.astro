---
import { ViewTransitions } from "astro:transitions";
import Cursor from "../components/Cursor.astro";
import Navbar from "../components/Navbar.astro";
import Preloader from "../components/Preloader.astro";
import StickyCopyright from "../components/StickyCopyright.astro";
const { hideGlobalPreloader = false, navTheme = "light" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/03.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wedding Candid | Editorial & Wedding Portfolio</title>
  <meta name="description" content="Modern, premium photography portfolio specializing in emotional storytelling and timeless imagery.">
  <!-- Fonts are globally handled via style.css -->
  <link rel="stylesheet" href="/style.css">
  <ViewTransitions />
</head>

<body class={hideGlobalPreloader ? "" : "preloader-active"} data-nav-theme={navTheme}>
  <!-- Preloader -->
  { !hideGlobalPreloader && <Preloader /> }

  <div id="app">
    <!-- Navbar -->
    <Navbar />
    
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        // ── Global Curtain Reveal Observer ────────────────
        const curtainObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              setTimeout(() => entry.target.classList.add('in'), 150);
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });

        document.querySelectorAll('.curtain-reveal').forEach(el => {
          curtainObserver.observe(el);
        });
      });
    </script>

    <!-- Main Content -->
    <main id="main-content">
      <slot />
    </main>

    <footer class="stagger-reveal">
      <div class="footer-grid">
        <div class="footer-logo-box">
          <img src="/03.png" alt="WC Footer Logo" style="height: 120px; width: auto; object-fit: contain; margin-bottom: 2rem;">
          <p class="footer-tagline">
            Dedicated to the quiet moments, the unspoken glances, and the light that defines us. Minimalist luxury photography for those who value authenticity.
          </p>
          <div class="footer-socials">
            <a href="https://www.instagram.com/wedding_candid?igsh=MTI4bjlnMDlzZjk0Mg==" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="social-icon"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              <span>Instagram</span>
            </a>
            <a href="https://youtube.com/@weddingcandiddeepmistry7777?si=zQwSc1Y0IJbYHID8" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="YouTube">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="social-icon"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.42a2.78 2.78 0 0 0-1.94 2C1 8.11 1 12 1 12s0 3.89.46 5.58a2.78 2.78 0 0 0 1.94 2c1.72.42 8.6.42 8.6.42s6.88 0 8.6-.42a2.78 2.78 0 0 0 1.94-2C23 15.89 23 12 23 12s0-3.89-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
              <span>YouTube</span>
            </a>
          </div>
        </div>
        <div class="footer-col">
          <h4>Photography</h4>
          <ul class="footer-links">
            <li><a href="/photography/wedding">Wedding</a></li>
            <li><a href="/photography/pre-wedding">Pre-Wedding</a></li>
            <li><a href="/photography/bw">B/W Noir</a></li>
            <li><a href="/photography/events">Events</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/portfolio">Quick Portfolio</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/testimonials">Testimonials</a></li>
            <li><a href="/booking">Enquire</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; 2024 WEDDING CANDID. ALL RIGHTS RESERVED.
      </div>
    </footer>
    
    <!-- Custom Interactive Cursor -->
    <Cursor />
    <StickyCopyright />
  </div>
  <style is:global>
    :root {
      --luxury-ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Selection color */
    ::selection {
      background: #d1b894;
      color: white;
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #f8f6f2; }
    ::-webkit-scrollbar-thumb { background: #d1b894; border-radius: 10px; }
  </style>

  <script src="/global.js" type="module"></script>
  <script>
    import Lenis from 'lenis'
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'

    gsap.registerPlugin(ScrollTrigger)

    const lenis = new Lenis()

    lenis.on('scroll', ScrollTrigger.update)

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000)
    })

    gsap.ticker.lagSmoothing(0)

    // REFRESH ENTIRE PAGE SCROLL LOGIC ON EVERY NAVIGATION
    document.addEventListener('astro:after-swap', () => {
      window.scrollTo(0, 0);
      lenis.scrollTo(0, { immediate: true });
      ScrollTrigger.refresh(true);
    });
    document.addEventListener('astro:page-load', () => {
      ScrollTrigger.refresh(true);
    });
  </script>
</body>
</html>
