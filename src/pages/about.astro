---
import Layout from '../layouts/Layout.astro';
---

<Layout hideGlobalPreloader={true}>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Playfair+Display:ital,wght@0,300;0,400;1,300;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet" />

  <div class="about-page">

    <!-- ══════════════════════════
         HERO — from version 1
    ══════════════════════════ -->
    <section class="profile-section">
      <div class="profile-container">
        <div class="profile-header">
          <p class="section-tag">Founder of Wedding Candid</p>
          <h1 class="director-name">Deep <em>Mistry</em></h1>
          <p class="director-titles">Photos / Director / Storyteller</p>
        </div>

        <div class="profile-content">
          <div class="profile-image-wrap">
            <div class="hero-quote-block">
              <blockquote class="manifesto-quote">
                "Relationships change in due period of time, <br />
                The only constant is the <em>memories</em> you captured in photographs"
              </blockquote>
              <p class="founder-tag-inline">Founder of : <strong>WEDDING CANDID</strong></p>
            </div>
            <div class="profile-image-inner">
              <img src="/about/IMG_8611.jpg" alt="Deep Mistry" />
            </div>
            <div class="profile-badge">EST. 2015</div>
          </div>

          <div class="profile-copy">
            <div class="bio-block">
              <p class="bio-intro">
                Deep Mistry is a professional Photographer / Cinematographer renowned for his creative imagery and profound storytelling abilities.
              </p>
              <div class="bio-divider"></div>
              <div class="bio-body">
                <p style="font-style: italic;">
                  "As an artist whose medium of bringing the art to the world is an intent of compartmentalising the moments, I am all about things which are not seen by the naked eye but a soul which feels what cannot be said through any other medium."
                </p>
                <p>
                  With a passion for capturing life's most cherished moments, he has carved a niche for himself in the world of photography over the last 9 years. As the founder of WEDDING CANDID, he has elevated the art of Wedding photography, transforming emotional moments into timeless treasures.
                </p>
                <p>
                  He has redefined the essence of Wedding photography. His distinctive eye for grabbing the ongoing moment results in stunning visual narratives that resonate deeply with his clients. Each wedding captured by him enables the client to cherish every event even years after its passing, weaving a rich tapestry of emotions, relationships, and memories.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════
         INTRO — from version 2
    ══════════════════════════ -->
    <section class="intro" data-reveal>
      <div class="intro__inner">
        <div class="intro__pull reveal-child">
          <p>
            I am a professional wedding photographer and filmmaker who has spent the last
            nine years doing one thing — being <em>fully present</em> at the most important
            day of your life.
          </p>
        </div>
        <div class="intro__body reveal-child">
          <p>
            My work is not about perfect poses or manufactured smiles. It is about the
            split-second glance between a father and his daughter before she walks down the
            aisle. The private laugh only the two of you share. The quiet exhale of a bride
            the moment everything becomes real. Those are the moments I live for — and the
            ones I will carry back to you, forever.
          </p>
          <p>
            As the founder of <strong>Wedding Candid</strong>, I have built a practice
            rooted in trust, emotion, and craft. Every frame I deliver is a piece of your
            story — not mine.
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════
         TURNING POINT — from version 2
    ══════════════════════════ -->
    <section class="turning" data-reveal>
      <div class="turning__inner">
        <div class="turning__left reveal-child">
          <span class="turning__label">The Moment Everything Changed</span>
          <div class="turning__line"></div>
        </div>
        <div class="turning__right">
          <h2 class="turning__headline reveal-child">
            My first wedding<br />taught me what<br /><em>this really means.</em>
          </h2>
          <div class="turning__copy reveal-child">
            <p>
              The moment I shot my first wedding, I felt the weight of it. These were not
              clients — they were people placing one of the most precious days of their lives
              in my hands. They trusted me completely. That trust changed how I approach
              every single wedding I photograph.
            </p>
            <p>
              I realised that the skills I had been sharpening for years were not just about
              beautiful photos. They carried <em>real weight</em> — the responsibility to
              preserve what can never be recreated, and to return it as a memory that grows
              richer with every passing year.
            </p>
            <p>
              Every time I pick up my camera, I feel that same quiet responsibility. And I
              would not have it any other way.
            </p>
          </div>
          <div class="turning__stat reveal-child">
            <span class="stat-num">9</span>
            <span class="stat-text">Years of weddings,<br/>each one irreplaceable</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════
         APPROACH — from version 2
    ══════════════════════════ -->
    <section class="approach" data-reveal>
      <div class="approach__inner">
        <p class="approach__eyebrow reveal-child">How I work</p>
        <h2 class="approach__headline reveal-child">
          I don't direct. I don't interrupt.<br />
          I simply <em>show up</em> — and let your<br />
          story unfold in front of me.
        </h2>
        <div class="approach__pillars reveal-child">
          <div class="pillar">
            <span class="pillar__num">I</span>
            <h3>Invisible Presence</h3>
            <p>You will feel completely at ease on your wedding day. My camera becomes part of the atmosphere, not a disruption to it.</p>
          </div>
          <div class="pillar">
            <span class="pillar__num">II</span>
            <h3>Emotional Storytelling</h3>
            <p>Every gallery I deliver tells the full arc of your day — from the nervous morning preparations to the last dance of the night.</p>
          </div>
          <div class="pillar">
            <span class="pillar__num">III</span>
            <h3>Lasting Craft</h3>
            <p>These photographs will outlive us. I treat them with the seriousness that deserves — every image deliberately made, never accidental.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════
         JOURNEY — from version 2
    ══════════════════════════ -->
    <section class="journey" data-reveal>
      <div class="journey__inner">
        <div class="journey__img-stack reveal-child">
          <img src="/about/IMG_4490.jpg" class="jstack-1" alt="Wedding moment" />
          <img src="/about/b4fc1a98-15f2-49ad-abf0-20a0ad3614c2.jpg" class="jstack-2" alt="Wedding moment" />
          <div class="journey__year-badge">2015 → Now</div>
        </div>
        <div class="journey__text">
          <p class="journey__eyebrow reveal-child">The Journey</p>
          <h2 class="journey__headline reveal-child">
            A Heritage<br />Built on <em>Commitment</em>
          </h2>
          <div class="journey__copy reveal-child">
            <p>
              I first picked up a camera in 2017 and bought my own in 2018. I spent months
              assisting on shoots, learning the craft from the ground up — from production
              sets to family portraits to smaller celebrations.
            </p>
            <p>
              One night, I made the decision to commit fully. I threw everything I had into
              building Wedding Candid — not just as a business, but as a promise to every
              couple who would ever trust me with their story.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════
         GOALS — from version 2
    ══════════════════════════ -->
    <section class="goals" data-reveal>
      <div class="goals__inner">
        <div class="goals__header reveal-child">
          <p class="goals__eyebrow">Beyond the lens</p>
          <h2 class="goals__headline">
            My goals are simple.<br /><em>But they're big.</em>
          </h2>
        </div>
        <div class="goals__grid">
          <div class="goal reveal-child">
            <span class="goal__n">01</span>
            <p>Grow Wedding Candid and let photography take my family all over the world.</p>
          </div>
          <div class="goal reveal-child">
            <span class="goal__n">02</span>
            <p>Be the best husband and father — every single day, without compromise.</p>
          </div>
          <div class="goal reveal-child">
            <span class="goal__n">03</span>
            <p>Own a studio space that becomes a blessing to other creatives in this city.</p>
          </div>
          <div class="goal reveal-child">
            <span class="goal__n">04</span>
            <p>Keep showing up for my friends — and collect plenty more tattoos along the way.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════
         LETTER — from version 2
    ══════════════════════════ -->
    <section class="letter" data-reveal>
      <div class="letter__inner reveal-child">
        <p class="letter__eyebrow">A note from Deep</p>
        <div class="letter__body">
          <p>
            Thank you for taking the time to read my story. I know you have many choices
            when it comes to your wedding photographer — and I don't take it lightly when
            someone stops to genuinely connect with what I do. It means more than I can say.
          </p>
          <p>
            If you are here, you are looking for someone who will care about your day as
            much as you do. I promise you — I will. I am excited for the chance to meet
            you, hear your story, and hopefully create something together that you will
            treasure for the rest of your lives.
          </p>
        </div>
        <div class="letter__sig">
          <span class="letter__dash">—</span>
          <span class="letter__name">Deep Mistry</span>
          <span class="letter__brand">Wedding Candid</span>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════
         CTA — from version 2
    ══════════════════════════ -->
    <section class="cta" data-reveal>
      <div class="cta__inner reveal-child">
        <h2 class="cta__headline">
          Let's tell your story<br /><em>together.</em>
        </h2>
        <p class="cta__sub">Every great wedding starts with a conversation.</p>
        <a href="/booking" class="cta__btn">Begin Your Story</a>
      </div>
    </section>

  </div>
</Layout>

<style>
  /* ── SHARED TOKENS ── */
  :root {
    --ink:        #1a1814;
    --paper:      #f8f6f2;
    --bg:         #faf9f6;
    --bg-soft:    #f2ede6;
    --bg-dark:    #1a1714;
    --ink-mid:    #57534e;
    --ink-light:  #a8a29e;
    --gold:       #b68b40;
    --gold-pale:  #e8d8bc;
    --ease:       cubic-bezier(0.16, 1, 0.3, 1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .about-page {
    background: var(--paper);
    color: var(--ink);
    overflow-x: hidden;
  }

  em { font-style: italic; color: var(--gold); }

  /* ══════════════════════════════
     REVEAL SYSTEM
  ══════════════════════════════ */
  .reveal-child {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.9s var(--ease), transform 0.9s var(--ease);
  }
  .reveal-child.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-child:nth-child(2) { transition-delay: 0.1s; }
  .reveal-child:nth-child(3) { transition-delay: 0.2s; }
  .reveal-child:nth-child(4) { transition-delay: 0.3s; }
  .reveal-child:nth-child(5) { transition-delay: 0.4s; }
  .reveal-child:nth-child(6) { transition-delay: 0.5s; }

  /* ══════════════════════════════
     HERO — version 1 styles
  ══════════════════════════════ */
  .profile-section {
    padding: 10rem 5vw 8rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .profile-header {
    text-align: center;
    margin-bottom: 8rem;
  }
  .section-tag {
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }
  .director-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 300;
    line-height: 1;
  }
  .director-name em { font-style: italic; color: var(--gold); }
  .director-titles {
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-top: 1.5rem;
  }

  .profile-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8vw;
    align-items: center;
  }

  .profile-image-wrap { position: relative; }
  .profile-image-inner {
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 4/5;
  }
  .hero-quote-block {
    margin-bottom: 2rem;
    text-align: left;
  }
  .manifesto-quote {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    font-weight: 300;
    line-height: 1.4;
    color: var(--ink);
    font-style: italic;
    margin-bottom: 0.8rem;
    border: none;
    padding: 0;
  }
  .manifesto-quote em { color: var(--gold); }
  .founder-tag-inline {
    font-family: 'Outfit', sans-serif;
    font-size: 0.70rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.6);
  }
  .founder-tag-inline strong { color: var(--gold); font-weight: 500; }
  .profile-image-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.05);
    transition: transform 1.2s var(--ease);
  }
  .profile-badge {
    position: absolute;
    bottom: -2rem; right: -2rem;
    background: var(--gold);
    color: white;
    padding: 2rem 1.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    border-radius: 2px;
    box-shadow: 0 10px 40px rgba(182,139,64,0.3);
  }

  .bio-block {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .bio-intro {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    line-height: 1.6;
    font-weight: 300;
  }
  .bio-divider {
    width: 60px; height: 1px; background: var(--gold);
  }
  .bio-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    line-height: 2;
    color: rgba(0,0,0,0.6);
  }

  /* ══════════════════════════════
     INTRO
  ══════════════════════════════ */
  .intro {
    padding: 8rem 6vw;
    background: var(--bg-soft);
  }
  .intro__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8vw;
    align-items: start;
  }
  .intro__pull p {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    font-weight: 300;
    line-height: 1.5;
    color: var(--ink);
  }
  .intro__pull em { color: var(--gold); font-style: italic; }
  .intro__body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 0.4rem;
  }
  .intro__body p {
    font-size: 1rem;
    line-height: 1.9;
    color: var(--ink-mid);
    font-weight: 300;
    font-family: 'Outfit', sans-serif;
  }
  .intro__body strong { color: var(--gold); font-weight: 500; }

  /* ══════════════════════════════
     TURNING POINT
  ══════════════════════════════ */
  .turning {
    padding: 10rem 6vw;
    background: var(--bg);
  }
  .turning__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 6vw;
    align-items: start;
  }
  .turning__left {
    padding-top: 0.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    position: sticky;
    top: 6rem;
  }
  .turning__label {
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    line-height: 1.7;
    font-weight: 500;
    font-family: 'Outfit', sans-serif;
  }
  .turning__line {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, var(--gold), transparent);
  }
  .turning__headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    font-weight: 300;
    line-height: 1.15;
    margin-bottom: 3rem;
    letter-spacing: -0.01em;
  }
  .turning__copy {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 60ch;
  }
  .turning__copy p {
    font-size: 1.05rem;
    line-height: 1.95;
    color: var(--ink-mid);
    font-weight: 300;
    font-family: 'Outfit', sans-serif;
  }
  .turning__copy em { color: var(--gold); font-style: italic; }
  .turning__stat {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--gold-pale);
  }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 5rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .stat-text {
    font-size: 0.8rem;
    color: var(--ink-light);
    line-height: 1.7;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 400;
    font-family: 'Outfit', sans-serif;
  }

  /* ══════════════════════════════
     APPROACH
  ══════════════════════════════ */
  .approach {
    padding: 10rem 6vw;
    background: var(--bg-soft);
    color: var(--ink);
  }
  .approach__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .approach__eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2.5rem;
    font-weight: 400;
    font-family: 'Outfit', sans-serif;
  }
  .approach__headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 300;
    line-height: 1.25;
    margin-bottom: 6rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .approach__headline em { color: var(--gold); font-style: italic; }
  .approach__pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }
  .pillar {
    padding: 3.5rem 2.5rem;
    background: var(--bg);
    border-top: 1px solid var(--gold-pale);
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    transition: background 0.4s;
  }
  .pillar:hover { background: var(--bg-soft); }
  .pillar__num {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-style: italic;
    color: var(--gold);
    font-weight: 300;
  }
  .pillar h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .pillar p {
    font-size: 0.9rem;
    line-height: 1.85;
    color: var(--ink-mid);
    font-weight: 300;
    font-family: 'Outfit', sans-serif;
  }

  /* ══════════════════════════════
     JOURNEY
  ══════════════════════════════ */
  .journey {
    padding: 10rem 6vw;
    background: var(--bg-soft);
  }
  .journey__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8vw;
    align-items: center;
  }
  .journey__img-stack {
    position: relative;
    aspect-ratio: 4/5;
  }
  .jstack-1, .jstack-2 {
    position: absolute;
    border-radius: 3px;
    object-fit: cover;
  }
  .jstack-1 {
    width: 82%; height: 75%;
    top: 0; right: 0;
    box-shadow: 20px 30px 80px rgba(0,0,0,0.12);
  }
  .jstack-2 {
    width: 68%; height: 60%;
    bottom: 0; left: 0;
    box-shadow: 10px 20px 60px rgba(0,0,0,0.1);
    border: 6px solid var(--bg-soft);
  }
  .journey__year-badge {
    position: absolute;
    bottom: 28%; right: -1rem;
    background: var(--bg);
    border: 1px solid var(--gold-pale);
    padding: 0.9rem 1.4rem;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    font-family: 'Outfit', sans-serif;
    z-index: 5;
  }
  .journey__eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2rem;
    font-weight: 400;
    font-family: 'Outfit', sans-serif;
  }
  .journey__headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 3rem;
    letter-spacing: -0.01em;
  }
  .journey__copy {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .journey__copy p {
    font-size: 1rem;
    line-height: 1.95;
    color: var(--ink-mid);
    font-weight: 300;
    font-family: 'Outfit', sans-serif;
  }

  /* ══════════════════════════════
     GOALS
  ══════════════════════════════ */
  .goals {
    padding: 10rem 6vw;
    background: var(--bg);
  }
  .goals__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .goals__header {
    margin-bottom: 6rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--gold-pale);
  }
  .goals__eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 400;
    font-family: 'Outfit', sans-serif;
    grid-column: 1 / -1;
