<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script is:inline>
  document.addEventListener('astro:page-load', () => {

    /* ── HERO GSAP ANIMATIONS (version 1) ── */
    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      const globalProfileHeader = document.querySelector('.profile-header');
      if (globalProfileHeader) {
        gsap.registerPlugin(ScrollTrigger);

        gsap.from('.profile-header', {
          opacity: 0, y: 60, duration: 1.4, ease: 'power3.out'
        });

        const heroItems = document.querySelectorAll('.hero-quote-block, .profile-image-inner, .bio-block');
        heroItems.forEach((item, i) => {
          gsap.from(item, {
            opacity: 0, y: 50, duration: 1.2, delay: i * 0.12,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: '.profile-content',
              start: 'top 85%',
            }
          });
        });

        gsap.to('.profile-image-inner img', {
          scale: 1, y: -40,
          scrollTrigger: {
            trigger: '.profile-image-wrap',
            start: 'top bottom',
            end: 'bottom top',
            scrub: true
          }
        });
      }
    }

    /* ── SCROLL REVEAL (version 2 — for all sections below hero) ── */
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const children = entry.target.querySelectorAll('.reveal-child');
          children.forEach((child, i) => {
            setTimeout(() => child.classList.add('is-visible'), i * 100);
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));

    /* ── JOURNEY PARALLAX (version 2) ── */
    const s1 = document.querySelector('.jstack-1');
    const s2 = document.querySelector('.jstack-2');
    if (s1 && s2) {
      const journeySection = document.querySelector('.journey');
      const onScroll = () => {
        const rect = journeySection.getBoundingClientRect();
        const progress = -rect.top / window.innerHeight;
        s1.style.transform = `translateY(${progress * -20}px)`;
        s2.style.transform = `translateY(${progress * 20}px)`;
      };
      window.addEventListener('scroll', onScroll, { passive: true });
    }

  });
</script>