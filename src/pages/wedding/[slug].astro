---
import Layout from '../../layouts/Layout.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';

export async function getStaticPaths() {
  const WEDDINGS = [
    {
      slug: 'aashvi-tej',
      name1: 'Aashvi',
      name2: 'Tej',
      subtitle: 'Moments in Light',
