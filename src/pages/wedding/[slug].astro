      quote: "Love is not just looking at each other, it's looking in the same direction.",
      next: { slug: 'vishwa-vishu', names: 'Vishwa & Vishu' },
      images: [
        '/gallery/mit-kinjal/083A4644.jpg', '/gallery/mit-kinjal/083A8242.jpg', '/gallery/mit-kinjal/083A8367.jpg',
        '/gallery/mit-kinjal/HR6_1343.jpg', '/gallery/mit-kinjal/SAM_5558.jpg', '/gallery/mit-kinjal/WC__6634.jpg',
        '/gallery/mit-kinjal/WC__6746.jpg', '/gallery/mit-kinjal/WC__6831.jpg', '/gallery/mit-kinjal/WC__6960.jpg',
        '/gallery/mit-kinjal/WC__7214.jpg', '/gallery/mit-kinjal/WC__8214.jpg', '/gallery/mit-kinjal/WC__8428.jpg'
      ]
    },
    {
      slug: 'vishwa-vishu',
      name1: 'Vishwa',
      name2: 'Vishu',
      subtitle: 'Infinite Grace Found',
      cover: '/gallery/vishwa-vishu/WC__0652.jpg',
      quote: "They did not fall in love. They rose into it — slowly, surely, like morning finding the hills.",
      next: { slug: 'parth-shivani', names: 'Parth & Shivani' },
      images: [
        '/gallery/vishwa-vishu/SAM_6798.JPG', '/gallery/vishwa-vishu/SAM_6825.JPG', '/gallery/vishwa-vishu/SAM_8290.JPG',
        '/gallery/vishwa-vishu/SAM_8501.JPG', '/gallery/vishwa-vishu/SAM_8751.JPG', '/gallery/vishwa-vishu/WC__0448.JPG',
        '/gallery/vishwa-vishu/WC__0794.JPG', '/gallery/vishwa-vishu/WC__0829.JPG', '/gallery/vishwa-vishu/WC__7272.JPG',
        '/gallery/vishwa-vishu/WC__7860.JPG', '/gallery/vishwa-vishu/WC__8320.JPG', '/gallery/vishwa-vishu/WC__9999.jpg'
      ]
    },
    {
      slug: 'parth-shivani',
      name1: 'Parth',
      name2: 'Shivani',
      subtitle: 'Two Souls, One Path',
      cover: '/gallery/parth-shivani/MBJ_8834.jpg',
      quote: "Two souls fluent in the same silence. Two names the universe kept whispering to itself.",
      next: { slug: 'riya-hardik', names: 'Riya & Hardik' },
      images: [
        '/gallery/parth-shivani/4W0A9481.jpg', '/gallery/parth-shivani/MBJ_9235.jpg', '/gallery/parth-shivani/RJT00423.jpg',
        '/gallery/parth-shivani/SAM_2574.jpg', '/gallery/parth-shivani/SAM_3119.jpg', '/gallery/parth-shivani/SDPH1356.jpg',
        '/gallery/parth-shivani/SDPH1772.jpg', '/gallery/parth-shivani/SDPH2220.jpg', '/gallery/parth-shivani/WC__5448.jpg'
      ]
    },
    {
      slug: 'riya-hardik',
      name1: 'Riya',
      name2: 'Hardik',
      subtitle: 'Soulful Connection',
      cover: '/gallery/riya-hardik/WC__5748.jpg',
      quote: "A soulmate is someone who has locks that fit our keys, and keys to fit our locks.",
      next: { slug: 'hemant-devanshi', names: 'Hemant & Devanshi' },
      images: [
        '/gallery/riya-hardik/MBJ_4897.jpg', '/gallery/riya-hardik/SAI_5399.jpg', '/gallery/riya-hardik/SAM_9970.jpg',
        '/gallery/riya-hardik/SDPH2516.jpg', '/gallery/riya-hardik/SDPH3632.jpg', '/gallery/riya-hardik/WC__2254.jpg',
        '/gallery/riya-hardik/WC__2706.jpg', '/gallery/riya-hardik/WC__2952.jpg', '/gallery/riya-hardik/WC__6780.jpg'
      ]
