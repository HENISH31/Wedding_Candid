      quote: "Where the sea meets the shore and two hearts meet forever — that is where their story begins.",
      next: { slug: 'mit-kinjal', names: 'Mit & Kinjal' },
      images: [
        '/gallery/aashvi-tej/MBJ_0095.jpg', '/gallery/aashvi-tej/SAM_2280.jpg', '/gallery/aashvi-tej/SUN05400.jpg',
        '/gallery/aashvi-tej/WC__2420.jpg', '/gallery/aashvi-tej/WC__2884.jpg', '/gallery/aashvi-tej/WC__3084.JPG',
