---
// gallery3d.astro — The Infinite Drag Canvas (Moodboard)
const IMAGES = [
  '/gallery/opt/198A1445.webp',
  '/gallery/opt/1M4A8828.webp',
  '/gallery/opt/CB8A0155.webp',
  '/gallery/opt/CB8A0325.webp',
  '/gallery/opt/DJI_20241209172706_0093_D_FLYCAPTURE.webp',
  '/gallery/opt/IMG_4312.webp',
  '/gallery/opt/MBJ_5953.webp',
  '/gallery/opt/SSP01330.webp',
  '/gallery/opt/WC_13299.webp',
  '/gallery/opt/WC_17354.webp',
  '/gallery/opt/WC_17407.webp',
  '/gallery/opt/WC_19833.webp',
  '/gallery/opt/WC__5748.webp',
  '/gallery/opt/WC__6391.webp',
  '/gallery/opt/WC__7232.webp',
  '/gallery/opt/WC__8428.webp',
];

const CAPTIONS = [
  'Bridal Embroidery','Garden Ceremony','Santorini Couple','Romantic Escape',
  'Aerial Palace','Forest Romance','Candid Kiss','Royal Palace',
  'Haldi Ceremony','Mist & Mountains','Baraat Entry','Flower Shower',
  'Night Portrait','Couple Portrait','Mystic Night','Golden Hour',
];

const ROWS = 40;
const COLS = 40;

// Generate a massive, perfectly interlocking editorial masonry grid
const cells = [];
for (let r = 0; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    const index = r * COLS + c;
    
    // Strict, beautifully calculated geometric patterns instead of random chaos
    const isPortrait = (index % 3 === 0);
    const isLandscape = (index % 3 === 1);
    
    const w = isPortrait ? 380 : (isLandscape ? 550 : 450);
    const h = isPortrait ? 550 : (isLandscape ? 380 : 450);
    
    // Perfectly crisp alignment gaps
    const xBase = (c - COLS / 2) * 580;
    const xOffset = (r % 2 !== 0) ? 290 : 0;
    
    const yBase = (r - ROWS / 2) * 580;

    cells.push({
      src: IMAGES[index % IMAGES.length],
      caption: CAPTIONS[index % CAPTIONS.length],
      num: index + 1,
      x: xBase + xOffset,
      y: yBase,
      width: w,
      height: h,
    });
  }
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Moodboard | Wedding Candid</title>

  {IMAGES.slice(0, 5).map(src => (
    <link rel="preload" as="image" href={src} />
  ))}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@0,400;0,500;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    
    html, body { 
      width: 100vw; 
      height: 100vh; 
      overflow: hidden; 
      background: #f4f2ec; /* Artist canvas color */
      color: #1a1814;
    }

    /* ── NAV ── */
    .gal-nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 3rem;
      pointer-events: none; /* Let clicks pass through when near top */
    }
    .gal-nav > * { pointer-events: auto; }
    
    .gal-nav-logo {
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      font-size: 1.5rem;
      color: #1a1814;
      text-decoration: none;
      filter: drop-shadow(0 2px 10px rgba(244,242,236,0.8));
    }
    .gal-nav-back {
      font-family: 'Outfit', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: #c9a84c;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .gal-nav-back:hover { opacity: 0.5; }

    /* Instructions helper */
    .instruction-tooltip {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      font-family: 'Outfit', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #7a7168;
      background: rgba(244,242,236,0.9);
      padding: 0.8rem 1.5rem;
      border-radius: 100px;
      backdrop-filter: blur(10px);
      z-index: 100;
      pointer-events: none;
      animation: fadeOutTooltip 4s forwards 2s;
    }
    @keyframes fadeOutTooltip {
      to { opacity: 0; visibility: hidden; }
    }

    /* ── INFINITE CANVAS ── */
    #drag-viewport {
      width: 100vw;
      height: 100vh;
      cursor: grab;
      position: relative;
      perspective: 2000px;
    }
    #drag-viewport:active {
      cursor: grabbing;
    }

    #canvas-plane {
      position: absolute;
      top: 50%;
      left: 50%;
      /* Will transform translate from JS */
      transform-origin: center;
      will-change: transform;
      transform-style: preserve-3d;
    }

    /* Studio Spotlight Effect Setup */
    #canvas-plane:hover .canvas-item {
      opacity: 0.4;
      filter: grayscale(80%) contrast(1.1);
    }

    .canvas-item {
      position: absolute;
      /* Removed padding & background for a pure borderless look */
      box-shadow: 0 15px 35px rgba(0,0,0,0.15);
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease, filter 0.6s ease, opacity 0.6s ease, z-index 0s;
      cursor: pointer;
      /* Center origin translation */
      transform: translate(-50%, -50%) scale(1);
      background: #000;
    }
    
    .canvas-item:hover {
      opacity: 1 !important;
      filter: grayscale(0%) contrast(1.05) !important;
      transform: translate(-50%, -50%) scale(1.06);
      z-index: 50 !important;
      box-shadow: 0 40px 100px rgba(0,0,0,0.4);
    }

    .canvas-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      pointer-events: none; /* Prevents ghost dragging */
    }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999;
      background: rgba(26,24,20,0.98);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      place-items: center;
      cursor: zoom-out;
    }
    .lightbox.open { display: grid; animation: lbWrap .3s ease both; }
    @keyframes lbWrap { from { opacity: 0; } to { opacity: 1; } }
    .lightbox img {
      max-width: 90vw;
      max-height: 85vh;
      object-fit: contain;
      border-radius: 4px;
      box-shadow: 0 40px 100px rgba(0,0,0,0.5);
      animation: lbIn .35s cubic-bezier(0.2, 1, 0.3, 1) both;
    }
    @keyframes lbIn {
      from { opacity: 0; transform: scale(0.9) translateY(20px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }
    .lb-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 3rem;
      pointer-events: none;
    }
    .lb-caption-text {
      font-family: 'Outfit', sans-serif;
      font-size: 0.8rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #f4f2ec;
      opacity: 0.6;
    }
    .lb-close {
      font-family: 'Outfit', sans-serif;
      font-size: 0.8rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #f4f2ec;
      cursor: pointer;
      opacity: 0.6;
      transition: opacity 0.2s;
      user-select: none;
      pointer-events: all;
    }
    .lb-close:hover { opacity: 1; text-shadow: 0 0 10px rgba(255,255,255,0.5); }
  </style>
</head>

<body>

  <nav class="gal-nav">
    <a href="/" class="gal-nav-logo">Wedding Candid</a>
    <a href="/" class="gal-nav-back">← Back</a>
  </nav>

  <div class="instruction-tooltip">
    Click & Drag to Explore
  </div>

  <div id="drag-viewport">
    <div id="canvas-plane">
      {cells.map((c, i) => (
        <div 
          class="canvas-item"
          style={`left: ${c.x}px; top: ${c.y}px; width: ${c.width}px; height: ${c.height}px; z-index: ${i};`}
          data-src={c.src}
          data-caption={c.caption}
        >
          <img src={c.src} alt={c.caption} loading="lazy" decoding="async" draggable="false" />
        </div>
      ))}
    </div>
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <div class="lb-header">
      <span class="lb-caption-text" id="lb-caption"></span>
      <span class="lb-close" id="lb-close">Close ✕</span>
    </div>
    <img id="lb-img" src="" alt="" />
  </div>

  <script is:inline>
    (function () {
      const viewport = document.getElementById('drag-viewport');
      const plane = document.getElementById('canvas-plane');
      
      let isDragging = false;
      let hasDragged = false; // to prevent click opening lightbox right after drag
      let startX, startY;
      let currentX = 0, currentY = 0;
      let translateX = 0, translateY = 0;
      // Target values for inertia smoothing
      let targetX = 0, targetY = 0;
      let dragStartX = 0, dragStartY = 0;

      // Inertia render loop
      function render() {
        // Calculate instantaneous velocity difference
        let vx = 0;
        let vy = 0;
        
        if (!isDragging) {
          // Soft deceleration map when letting go
          vx = (targetX - currentX) * 0.08;
          vy = (targetY - currentY) * 0.08;
          currentX += vx;
          currentY += vy;
        } else {
          // Direct sync while dragging, keeping track of delta for effects
          vx = (targetX - currentX) * 0.4;
          vy = (targetY - currentY) * 0.4;
          currentX += vx;
          currentY += vy;
        }

        // Kinetic Spatial Distortion (The Awwwards Effect)
        // When scrolling fast (vx/vy is high), the grid leans and warps into the drag physically!
        const rotateY = Math.max(-15, Math.min(15, vx * 0.5)); // 3D tilt horizontally
        const rotateX = Math.max(-15, Math.min(15, -vy * 0.5)); // 3D tilt vertically
        // Dynamic push-back scale when moving rapidly
        const scale = Math.max(0.9, 1 - (Math.abs(vx) + Math.abs(vy)) * 0.001);

        plane.style.transform = `translate(${currentX}px, ${currentY}px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(${scale})`;
        requestAnimationFrame(render);
      }
      render();

      function onPointerDown(e) {
        if (e.target.closest('.lightbox') || e.target.closest('nav')) return;
        
        isDragging = true;
        hasDragged = false;
        
        // Use clientX / touches
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;

        startX = clientX;
        startY = clientY;
        dragStartX = targetX;
        dragStartY = targetY;
      }

      // Hard limits to prevent scrolling into the void
      const MAX_PAN = 6800; // Keeps them safely inside the 1,600 image grid

      function onPointerMove(e) {
        if (!isDragging) return;
        
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;

        const dx = clientX - startX;
        const dy = clientY - startY;

        if (Math.abs(dx) > 5 || Math.abs(dy) > 5) {
          hasDragged = true; // User actually moved, flag as dragging
        }

        targetX = Math.max(-MAX_PAN, Math.min(MAX_PAN, dragStartX + dx));
        targetY = Math.max(-MAX_PAN, Math.min(MAX_PAN, dragStartY + dy));
      }

      function onPointerUp() {
        isDragging = false;
      }

      // Mouse Events
      viewport.addEventListener('mousedown', onPointerDown);
      window.addEventListener('mousemove', onPointerMove);
      window.addEventListener('mouseup', onPointerUp);

      // Touch Events for Mobile
      viewport.addEventListener('touchstart', onPointerDown, {passive: true});
      window.addEventListener('touchmove', onPointerMove, {passive: true});
      window.addEventListener('touchend', onPointerUp);

      // Mouse Wheel Panning (Extra Navigation method)
      window.addEventListener('wheel', (e) => {
        // Slowing down the mouse wheel speed for a more luxurious, heavy feel
        targetX -= e.deltaX * 0.55;
        targetY -= e.deltaY * 0.55;
        
        // Clamp bounds for wheel too
        targetX = Math.max(-MAX_PAN, Math.min(MAX_PAN, targetX));
        targetY = Math.max(-MAX_PAN, Math.min(MAX_PAN, targetY));
      }, { passive: true });

      // Lightbox Logic
      const lightbox = document.getElementById('lightbox');
      const lbImg = document.getElementById('lb-img');
      const lbCap = document.getElementById('lb-caption');
      const lbClose = document.getElementById('lb-close');

      viewport.addEventListener('click', (e) => {
        if (hasDragged) return; // Prevent clicking open if we were just dragging
        
        const cell = e.target.closest('.canvas-item');
        if (!cell) return;
        
        lbImg.src = cell.dataset.src;
        lbImg.alt = cell.dataset.caption || '';
        lbCap.textContent = cell.dataset.caption || '';
        lightbox.classList.add('open');
      });

      function closeLightbox() {
        lightbox.classList.remove('open');
        setTimeout(() => { lbImg.src = ''; }, 300);
      }

      lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
      lbClose.addEventListener('click', closeLightbox);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

    })();
  </script>

</body>
</html>
