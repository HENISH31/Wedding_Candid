---
// gallery.astro — Fan Reveal, fully fixed (5 bugs resolved)
const IMAGES = [
  '/gallery/opt/198A1445.webp',
  '/gallery/opt/1M4A8828.webp',
  '/gallery/opt/CB8A0155.webp',
  '/gallery/opt/CB8A0325.webp',
  '/gallery/opt/DJI_20241209172706_0093_D_FLYCAPTURE.webp',
  '/gallery/opt/IMG_4312.webp',
  '/gallery/opt/MBJ_5953.webp',
  '/gallery/opt/SSP01330.webp',
  '/gallery/opt/WC_13299.webp',
  '/gallery/opt/WC_17354.webp',
  '/gallery/opt/WC_17407.webp',
  '/gallery/opt/WC_19833.webp',
  '/gallery/opt/WC__5748.webp',
  '/gallery/opt/WC__6391.webp',
  '/gallery/opt/WC__7232.webp',
  '/gallery/opt/WC__8428.webp',
];

const CAPTIONS = [
  'Bridal Embroidery','Garden Ceremony','Santorini Couple','Romantic Escape',
  'Aerial Palace','Forest Romance','Candid Kiss','Royal Palace',
  'Haldi Ceremony','Mist & Mountains','Baraat Entry','Flower Shower',
  'Night Portrait','Couple Portrait','Mystic Night','Golden Hour',
];

const COLS = 5;
const ROWS = 80; // 80 rows (400 images) is the maximum for instant loading.

const cells = Array.from({ length: ROWS * COLS }, (_, i) => ({
  src:     IMAGES[i % IMAGES.length],
  caption: CAPTIONS[i % CAPTIONS.length],
  num:     i + 1,
  col:     i % COLS,   // 0-4, drives fan direction via CSS data-col
}));
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gallery | Wedding Candid</title>

  {IMAGES.slice(0, COLS).map(src => (
    <link rel="preload" as="image" href={src} />
  ))}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@0,400;0,500;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1/bundled/lenis.min.js"></script>

  <style>
    /* ── RESET ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cols: 5;
      --gap:  12px;
      --ink:  #2a2118;
      --gold: #b8935a;
      --ease: cubic-bezier(.16, 1, .3, 1);
    }

    html { overflow-x: hidden; background: #fff; }
    html.lenis { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto; }
    .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
    .lenis.lenis-stopped { overflow: hidden; }

    body {
      min-height: 100vh;
      background: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ── NAV ── */
    .gal-nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.2rem 3rem;
      background: rgba(245,240,232,.92);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(42,33,24,.06);
    }
    .gal-nav-logo {
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      font-size: 1.4rem;
      font-weight: 400;
      letter-spacing: .05em;
      color: var(--ink);
      text-decoration: none;
    }
    .gal-nav-back {
      font-family: 'Outfit', sans-serif;
      font-size: .7rem;
      letter-spacing: .35em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      transition: opacity .2s;
    }
    .gal-nav-back:hover { opacity: .6; }

    /* ── HERO ── */
    .gal-hero {
      padding: 12rem 2rem 5rem;
      text-align: center;
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 1.2s var(--ease), transform 1.2s var(--ease);
      will-change: transform, opacity;
    }
    .gal-hero.show {
      opacity: 1;
      transform: translateY(0);
    }
    .gal-eyebrow {
      font-family: 'Outfit', sans-serif;
      font-size: .65rem;
      letter-spacing: .55em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
      opacity: 0;
      animation: fadeUp .9s var(--ease) .2s both;
    }
    .gal-title {
      font-family: 'Bodoni Moda', serif;
      font-size: clamp(3rem, 9vw, 7rem);
      font-weight: 400;
      color: var(--ink);
      line-height: 1;
      letter-spacing: .04em;
      opacity: 0;
      animation: fadeUp 1.1s var(--ease) .4s both;
    }
    .gal-sub {
      margin-top: 1.1rem;
      font-family: 'Outfit', sans-serif;
      font-size: .88rem;
      color: rgba(42,33,24,.48);
      letter-spacing: .2em;
      opacity: 0;
      animation: fadeUp .9s var(--ease) .7s both;
    }
    .gal-sep {
      width: 1px; height: 56px;
      background: linear-gradient(to bottom, transparent, var(--gold), transparent);
      margin: 1.2rem auto 0;
      opacity: 0;
      animation: fadeUp .8s ease 1.1s both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: none; }
    }

    /* ── GRID ── */
    .gal-stage {
      width: 100%;
      max-width: 1500px;    /* FIX 5: cap width so cells aren't huge on wide monitors */
      margin: 0 auto;
      padding: 0 2rem 8rem;
    }
    .gal-grid {
      display: grid;
      grid-template-columns: repeat(var(--cols), 1fr);
      gap: 20px;
      width: 100%;
    }

    /* ══════════════════════════════════════════════════════════
       FIX 1 — CSS TRANSITIONS instead of @keyframes
       
       WHY: keyframe animations can't reverse. When .show is
       removed on scroll-up, transitions play backwards for free.
       No JS animation code needed at all.

       HOW: each data-col sets a unique "closed/hidden" pose.
       .show resets all to the natural position.
       CSS transition handles both the open AND close movement.
    ══════════════════════════════════════════════════════════ */
    .g-cell {
      width: 100%;
      height: 0;
      padding-bottom: 66.6%;
      position: relative;
      overflow: hidden;
      border-radius: 4px;
      cursor: pointer;
      background: #fcfbf8;
      transition: transform .7s var(--ease), opacity .7s var(--ease);
      will-change: transform, opacity;
      opacity: 0;
      transform: translateY(30px);
    }
    .g-cell.show {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Per-column hidden/fan-closed pose ──
       FIX 1: these replace the old @keyframes from states.
       Each column fans from a different angle.
       transform-origin controls which corner it pivots from.    */

    .g-cell[data-col="0"] {
      opacity: 0; filter: grayscale(1);
      transform: perspective(900px) rotate(-60deg) scale(.18) translateY(40px);
      transform-origin: left bottom;
    }
    .g-cell[data-col="1"] {
      opacity: 0; filter: grayscale(1);
      transform: perspective(900px) rotate(-36deg) scale(.78) translateY(40px);
      transform-origin: left bottom;
    }
    .g-cell[data-col="2"] {
      opacity: 0; filter: grayscale(1);
      transform: perspective(900px) scale(.82) translateY(64px);
      transform-origin: bottom center;
    }
    .g-cell[data-col="3"] {
      opacity: 0; filter: grayscale(1);
      transform: perspective(900px) rotate(36deg) scale(.78) translateY(40px);
      transform-origin: right bottom;
    }
    .g-cell[data-col="4"] {
      opacity: 0; filter: grayscale(1);
      transform: perspective(900px) rotate(60deg) scale(.18) translateY(40px);
      transform-origin: right bottom;
    }

    /* ── .show: settled natural position (ALL columns resolve here) ──
       FIX 2+3: single class controls both fan reveal AND colour reveal.
       No separate focusIO needed. grayscale is part of the same transition. */
    .g-cell.show {
      opacity: 1;
      filter: grayscale(0);
      transform: perspective(900px) rotate(0deg) scale(1) translateY(0);
    }

    /* Stagger per column when opening (scroll-down wave) */
    .g-cell.show[data-col="0"] { transition-delay: 0ms; }
    .g-cell.show[data-col="1"] { transition-delay: 80ms; }
    .g-cell.show[data-col="2"] { transition-delay: 160ms; }
    .g-cell.show[data-col="3"] { transition-delay: 80ms; }
    .g-cell.show[data-col="4"] { transition-delay: 0ms; }

    /* No stagger when closing (scroll-up feels snappier without delay) */
    .g-cell[data-col="0"],
    .g-cell[data-col="1"],
    .g-cell[data-col="2"],
    .g-cell[data-col="3"],
    .g-cell[data-col="4"] { transition-delay: 0ms; }

    /* ── Hover: lift + gold ring (only when already visible) ── */
    .g-cell.show:hover {
      box-shadow:
        0 16px 40px rgba(42,33,24,.22),
        0 0 0 2px rgba(184,147,90,.55);
      transform:
        perspective(900px)
        rotateX(var(--rx, 0deg))
        rotateY(var(--ry, 0deg))
        translateY(-4px) scale(1.01);
      transition-delay: 0ms !important;
    }

    /* ── Image ── */
    .g-cell img {
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 10;
      filter: grayscale(100%);
      transition: transform .7s var(--ease), filter .9s ease;
    }
    .g-cell.show img { filter: grayscale(0%); }
    .g-cell:hover img { transform: scale(1.08); }

    /* ── Numbering ── */

    .g-num {
      position: absolute;
      bottom: .8rem; right: .85rem;
      font-family: 'Outfit', sans-serif;
      font-size: .55rem;
      letter-spacing: .18em;
      color: rgba(255,255,255,.6);
      transform: translateY(4px);
      opacity: 0;
      transition: transform .4s var(--ease) .05s, opacity .35s ease .05s;
      z-index: 5;
    }
    .g-cell.show:hover .g-num { transform: translateY(0); opacity: 1; }

    /* ── LOADER ── */
    .gal-loader {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 4rem 0;
      gap: 8px;
      min-height: 120px;
    }
    .gal-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--gold);
      animation: dot 1.4s ease-in-out infinite;
    }
    .gal-dot:nth-child(2) { animation-delay: .2s; }
    .gal-dot:nth-child(3) { animation-delay: .4s; }
    @keyframes dot {
      0%,80%,100% { transform: scale(.5); opacity: .25; }
      40%         { transform: scale(1);  opacity: 1; }
    }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999;
      background: rgba(245,240,232,.95);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      place-items: center;
      cursor: zoom-out;
    }
    .lightbox.open { display: grid; animation: lbWrap .3s ease both; }
    @keyframes lbWrap { from { opacity: 0; } to { opacity: 1; } }
    .lightbox img {
      max-width: 90vw;
      max-height: 85vh;
      object-fit: contain;
      border-radius: 6px;
      box-shadow: 0 40px 100px rgba(42,33,24,.2);
      animation: lbIn .35s var(--ease) both;
    }
    @keyframes lbIn {
      from { opacity: 0; transform: scale(.91) translateY(12px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }
    .lb-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.4rem 2.5rem;
      pointer-events: none;
    }
    .lb-caption-text {
      font-family: 'Outfit', sans-serif;
      font-size: .72rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--ink);
      opacity: .55;
    }
    .lb-close {
      font-family: 'Outfit', sans-serif;
      font-size: .7rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--ink);
      cursor: pointer;
      opacity: .45;
      transition: opacity .2s;
      user-select: none;
      pointer-events: all;
    }
    .lb-close:hover { opacity: 1; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1000px) { :root { --cols: 3; } }
    @media (max-width: 650px)  { :root { --cols: 2; } }
  </style>
</head>

<body>

  <nav class="gal-nav">
    <a href="/" class="gal-nav-logo">Wedding Candid</a>
    <a href="/" class="gal-nav-back">← Back</a>
  </nav>

  <header class="gal-hero">
    <p class="gal-eyebrow">Wedding Candid Collection</p>
    <h1 class="gal-title">The Gallery</h1>
    <p class="gal-sub">Every frame, a feeling — hover to feel the moment</p>
    <div class="gal-sep"></div>
  </header>

  <div class="gal-stage">
    <div class="gal-grid" id="gal-grid">
      {cells.map((c, i) => (
        <div
          class="g-cell"
          data-col={String(c.col)}
          data-src={c.src}
          data-caption={c.caption}
        >
          <img
            src={c.src}
            alt={c.caption}
            loading={i < 10 ? 'eager' : 'lazy'}
            decoding="async"
          />
          <span class="g-num">#{String(c.num).padStart(3,'0')}</span>
        </div>
      ))}
    </div>

    <!-- End of curated collection -->
  </div>

  <div class="lightbox" id="lightbox">
    <div class="lb-header">
      <span class="lb-caption-text" id="lb-caption"></span>
      <span class="lb-close" id="lb-close">Close ✕</span>
    </div>
    <img id="lb-img" src="" alt="" />
  </div>

</body>

<script is:inline>
(function () {
  var IMAGES = [
    '/gallery/opt/198A1445.webp','/gallery/opt/1M4A8828.webp','/gallery/opt/CB8A0155.webp','/gallery/opt/CB8A0325.webp',
    '/gallery/opt/DJI_20241209172706_0093_D_FLYCAPTURE.webp','/gallery/opt/IMG_4312.webp','/gallery/opt/MBJ_5953.webp','/gallery/opt/SSP01330.webp',
    '/gallery/opt/WC_13299.webp','/gallery/opt/WC_17354.webp','/gallery/opt/WC_17407.webp','/gallery/opt/WC_19833.webp',
    '/gallery/opt/WC__5748.webp','/gallery/opt/WC__6391.webp','/gallery/opt/WC__7232.webp','/gallery/opt/WC__8428.webp'
  ];
  var CAPTIONS = [
    'Bridal Embroidery','Garden Ceremony','Santorini Couple','Romantic Escape',
    'Aerial Palace','Forest Romance','Candid Kiss','Royal Palace',
    'Haldi Ceremony','Mist & Mountains','Baraat Entry','Flower Shower',
    'Night Portrait','Couple Portrait','Mystic Night','Golden Hour',
  ];

  var grid     = document.getElementById('gal-grid');
  var sentinel = document.getElementById('gal-sentinel');
  var lightbox = document.getElementById('lightbox');
  var lbImg    = document.getElementById('lb-img');
  var lbClose  = document.getElementById('lb-close');
  var lbCap    = document.getElementById('lb-caption');
  var nextIdx  = 0;
  var totalNum = 0;
  var isLoading = false; // FIX 5: loading lock prevents rapid-fire dumps

  function getCols() {
    return parseInt(getComputedStyle(document.documentElement).getPropertyValue('--cols')) || 5;
  }

  /* ══════════════════════════════════════════════════════════
     FIX 1+2+3 — SINGLE FAN OBSERVER
     
     One observer. Toggles .show on enter, removes on exit.
     CSS transitions handle the animation in BOTH directions.
     
     rootMargin '0px 0px -30px 0px':
       - No more 200px early trigger (FIX 2)
       - Cell must be 30px inside bottom of viewport before opening
     
     .show controls both fan reveal AND grayscale→colour (FIX 3)
     No separate focusIO needed anymore.
  ══════════════════════════════════════════════════════════ */
  var fanIO = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      entry.target.classList.toggle('show', entry.isIntersecting);
    });
  }, {
    threshold: 0,
    rootMargin: '200px 0px 200px 0px'
  });

  document.querySelectorAll('.g-cell, .gal-hero').forEach(function (c) {
    fanIO.observe(c);
  });

  /* ── 3D Tilt ── */
  var MAX_TILT = 7;
  function attachTilt(cell) {
    cell.addEventListener('mousemove', function (e) {
      if (!cell.classList.contains('show')) return;
      var r = cell.getBoundingClientRect();
      var x = (e.clientX - r.left) / r.width  - 0.5;
      var y = (e.clientY - r.top)  / r.height - 0.5;
      cell.style.setProperty('--rx', (-y * MAX_TILT * 2) + 'deg');
      cell.style.setProperty('--ry', ( x * MAX_TILT * 2) + 'deg');
    });
    cell.addEventListener('mouseleave', function () {
      cell.style.setProperty('--rx', '0deg');
      cell.style.setProperty('--ry', '0deg');
    });
  }
  document.querySelectorAll('.g-cell').forEach(attachTilt);

  /* ══════════════════════════════════════════════════════════
     FIX 4+5 — INFINITE SCROLL with data-col + loading lock

     FIX 4: makeCell now sets data-col so new cells get the
     correct fan pose via CSS and are observed by fanIO.
     
     FIX 5: isLoading flag + smaller rootMargin (400px instead
     of 1000px) prevents multiple simultaneous row dumps on
     fast scroll.
  ══════════════════════════════════════════════════════════ */
  function makeCell(colIdx, rowNum) {
    var src     = IMAGES[nextIdx % IMAGES.length];
    var caption = CAPTIONS[nextIdx % CAPTIONS.length];
    var num     = ++totalNum;
    var cell    = document.createElement('div');

    cell.dataset.src     = src;
    cell.dataset.caption = caption;
    cell.dataset.col     = String(colIdx);
    cell.className       = 'g-cell';

    cell.innerHTML =
      '<img src="' + src + '" alt="' + caption + '" loading="lazy" decoding="async">' +
      '<span class="g-num">#' + String(num).padStart(3,'0') + '</span>';

    fanIO.observe(cell);
    attachTilt(cell);
    nextIdx++;
    return cell;
}

  function appendRows(count) {
    if (isLoading) return;       // FIX 5: block re-entry
    isLoading = true;

    requestAnimationFrame(function () {
      var frag = document.createDocumentFragment();
      var cols = getCols();
      for (var r = 0; r < count; r++) {
        for (var c = 0; c < cols; c++) {
          frag.appendChild(makeCell(c, r));
        }
      }
      grid.appendChild(frag);
      isLoading = false;         // FIX 5: unlock only after appending
    });
  }

  // Seed totalNum from existing SSR cells so numbering continues
  totalNum = document.querySelectorAll('.g-cell').length;
  nextIdx  = totalNum;

  var loadIO = new IntersectionObserver(function (ents) {
    if (ents[0].isIntersecting) appendRows(5); // 5 rows at a time (was 10)
  }, { rootMargin: '400px' });               // 400px (was 1000px — too aggressive)
  // loadIO.observe(sentinel); 

  /* ── Lightbox ── */
  grid.addEventListener('click', function (e) {
    var cell = e.target.closest('.g-cell');
    if (!cell) return;
    lbImg.src = cell.dataset.src;
    lbImg.alt = cell.dataset.caption || '';
    lbCap.textContent = cell.dataset.caption || '';
    lightbox.classList.add('open');
  });
  function closeLightbox() {
    lightbox.classList.remove('open');
    setTimeout(function () { lbImg.src = ''; }, 300);
  }
  lightbox.addEventListener('click', function (e) { if (e.target === lightbox) closeLightbox(); });
  lbClose.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeLightbox(); });

  /* ── Lenis smooth scroll ── */
  var lenis = new Lenis({
    duration: 1.2,
    easing: function (t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)); },
    smoothWheel: true,
    orientation: 'vertical'
  });
  function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);
})();
</script>

</html>
