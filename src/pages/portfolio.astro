---
import Layout from '../layouts/Layout.astro';

const IMAGES = [
  '/gallery/opt/198A1445.webp',
  '/gallery/opt/1M4A8828.webp',
  '/gallery/opt/CB8A0155.webp',
  '/gallery/opt/CB8A0325.webp',
  '/gallery/opt/DJI_20241209172706_0093_D_FLYCAPTURE.webp',
  '/gallery/opt/IMG_4312.webp',
  '/gallery/opt/MBJ_5953.webp',
  '/gallery/opt/SSP01330.webp',
  '/gallery/opt/WC_13299.webp',
  '/gallery/opt/WC_17354.webp',
  '/gallery/opt/WC_17407.webp',
  '/gallery/opt/WC_19833.webp',
  '/gallery/opt/WC__5748.webp',
  '/gallery/opt/WC__6391.webp',
  '/gallery/opt/WC__7232.webp',
  '/gallery/opt/WC__8428.webp',
];
---

<Layout hideGlobalPreloader={true}>
  <article class="portfolio-exhibition">
    <header class="portfolio-header">
      <h1 class="portfolio-title">Portfolio <em>Exhibition</em></h1>
    </header>

    <section class="story-gallery-sec">
      <div class="masonry-grid">
        {IMAGES.map((src, i) => {
          // Dynamic varied ratios to mimic the asymmetrical 5-column reference layout
          const ratios = [
            '1/1.2', '1/2', 
            '1/1.7', '1/1.1', '1/1.4',
            '1/1', '1/2.2', 
            '1/1.8', '1/1',
            '1/1.3', '1/2', '1/1.5',
            '1/1.6', '1/1.1', '1/1.8', 
            '1/1'
          ];
          const ratio = ratios[i % ratios.length];
          return (
            <div class="gallery-item" data-index={i} style={`aspect-ratio: ${ratio}`}>
              <div class="gallery-item-inner">
                <img src={src} alt={`Wedding Candid ${i + 1}`} loading={i < 4 ? 'eager' : 'lazy'} />
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <footer class="portfolio-footer">
      <span>— Wedding Candid Portfolio —</span>
    </footer>

    <!-- Light Lightbox -->
    <div id="portfolioLightbox" class="port-lightbox" hidden>
      <div class="port-lb-header">
        <span class="port-lb-counter" id="portCounter"></span>
        <button class="port-lb-close" id="portClose">✕</button>
      </div>
      <div class="port-lb-stage">
        <button class="port-lb-arrow prev" id="portPrev">&#8592;</button>
        <div class="port-lb-img-wrap">
          <img id="portLbImg" src="" alt="Portfolio View" />
        </div>
        <button class="port-lb-arrow next" id="portNext">&#8594;</button>
      </div>
    </div>
  </article>
</Layout>

<style>
  :root {
    --paper: #f5f1eb;
    --ink: #1a1814;
    --gold: #b68b40;
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
  }

  .portfolio-exhibition {
    background: var(--paper);
    color: var(--ink);
    min-height: 100vh;
    padding: 100px 0 0;
  }

  .portfolio-header {
    text-align: center;
    margin-bottom: 60px;
    padding: 0 2rem;
  }

  .portfolio-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.5rem;
  }
  .portfolio-title em { font-style: italic; color: var(--gold); }

  /* ── Masonry Grid ── */
  .story-gallery-sec { padding: 0 2vw 6rem; }
  .masonry-grid { column-count: 5; column-gap: 0.8vw; margin-top: 1rem; }
  @media (max-width: 1400px) { .masonry-grid { column-count: 4; } }
  @media (max-width: 1024px) { .masonry-grid { column-count: 3; } }
  @media (max-width: 768px)  { .masonry-grid { column-count: 2; column-gap: 1.5vw; } }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 0.8vw;
    overflow: hidden;
    background: #e8e4de;
    cursor: zoom-in;
  }
  .gallery-item-inner { position: relative; width: 100%; height: 100%; }
  .gallery-item img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.8s var(--ease);
  }
  .gallery-item:hover img { transform: scale(1.04); }

  .portfolio-footer {
    text-align: center;
    padding: 80px 2rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  /* ── Light Lightbox ── */
  .port-lightbox {
    position: fixed;
    inset: 0;
    z-index: 100000;
    background: rgba(245, 241, 235, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s var(--ease), visibility 0.4s;
  }
  .port-lightbox.open { opacity: 1; visibility: visible; }

  /* Header row: counter left, close right */
  .port-lb-header {
    height: 64px;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    flex-shrink: 0;
  }
  .port-lb-counter {
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--gold);
  }
  .port-lb-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--ink);
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.2s;
    line-height: 1;
    padding: 0.3rem 0.5rem;
  }
  .port-lb-close:hover { opacity: 1; }

  /* Stage: arrow | image | arrow */
  .port-lb-stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    gap: 1rem;
    min-height: 0;
  }

  /* Image container */
  .port-lb-img-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-width: 0;
  }
  .port-lb-img-wrap img {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    display: block;
    border-radius: 2px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.1);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  /* Arrow buttons */
  .port-lb-arrow {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.12);
    background: white;
    color: var(--ink);
    font-size: 1.3rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.25s, border-color 0.25s, transform 0.2s, color 0.25s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }
  .port-lb-arrow:hover {
    background: var(--gold);
    border-color: var(--gold);
    color: white;
    transform: scale(1.08);
  }

  @media (max-width: 640px) {
    .port-lb-arrow { width: 40px; height: 40px; font-size: 1rem; }
    .port-lb-stage { padding: 1rem 0.5rem; gap: 0.4rem; }
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const lightbox  = document.getElementById('portfolioLightbox');
    const lbImg     = document.getElementById('portLbImg');
    const counter   = document.getElementById('portCounter');
    const closeBtn  = document.getElementById('portClose');
    const prevBtn   = document.getElementById('portPrev');
    const nextBtn   = document.getElementById('portNext');
    const items     = Array.from(document.querySelectorAll('.gallery-item'));
    const srcs      = items.map(it => it.querySelector('img').src);
    const total     = srcs.length;
    let cIdx        = 0;

    if (!lightbox || !items.length) return;

    function updateLb() {
      lbImg.src = srcs[cIdx];
      counter.textContent = String(cIdx + 1).padStart(2, '0') + ' — ' + String(total).padStart(2, '0');
    }

    function openLb(i) {
      cIdx = i;
      updateLb();
      lightbox.removeAttribute('hidden');
      requestAnimationFrame(() => lightbox.classList.add('open'));
      document.body.style.overflow = 'hidden';
    }

    function closeLb() {
      lightbox.classList.remove('open');
      setTimeout(() => {
        lightbox.setAttribute('hidden', '');
        document.body.style.overflow = '';
      }, 420);
    }

    function navigate(dir) {
      cIdx = (cIdx + dir + total) % total;
      lbImg.style.opacity = '0';
      lbImg.style.transform = 'scale(0.95)';
      setTimeout(() => {
        updateLb();
        lbImg.style.opacity = '1';
        lbImg.style.transform = 'scale(1)';
      }, 180);
    }

    // Wire up clicks
    items.forEach((item, i) => item.addEventListener('click', () => openLb(i)));
    closeBtn.addEventListener('click', closeLb);
    prevBtn.addEventListener('click', () => navigate(-1));
    nextBtn.addEventListener('click', () => navigate(1));

    // Click backdrop (not image) to close
    lightbox.addEventListener('click', e => {
      if (e.target === lightbox || e.target.classList.contains('port-lb-stage')) closeLb();
    });

    // Keyboard
    document.addEventListener('keydown', e => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'ArrowLeft')  navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
      if (e.key === 'Escape')     closeLb();
    });
  });
</script>

