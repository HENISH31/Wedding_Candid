---
import Layout from '../layouts/Layout.astro';

const IMAGES = [
  '/gallery/quick-portfolio/083A8242.jpg',
  '/gallery/quick-portfolio/1M4A8828.jpg',
  '/gallery/quick-portfolio/DJI_0639.jpg',
  '/gallery/quick-portfolio/HR6_0303.JPG',
  '/gallery/quick-portfolio/IMG_2653.JPG',
  '/gallery/quick-portfolio/MBJ_0152.jpg',
  '/gallery/quick-portfolio/SAM_0359.jpg',
  '/gallery/quick-portfolio/SDPH1468.jpg',
  '/gallery/quick-portfolio/SSP01330.JPG',
  '/gallery/quick-portfolio/WC_11751.JPG',
  '/gallery/quick-portfolio/WC_13299.jpg',
  '/gallery/quick-portfolio/WC_17104.JPG',
  '/gallery/quick-portfolio/WC__0146.JPG',
  '/gallery/quick-portfolio/WC__0334.jpg',
  '/gallery/quick-portfolio/WC__2107.jpg',
  '/gallery/quick-portfolio/WC__3127.JPG',
  '/gallery/quick-portfolio/WC__5748.jpg',
  '/gallery/quick-portfolio/WC__6391.jpg',
  '/gallery/quick-portfolio/WC__7232.jpg',
  '/gallery/quick-portfolio/WC__8428.jpg'
];
---

<Layout hideGlobalPreloader={true}>
  <article class="portfolio-exhibition">
    <header class="portfolio-header">
      <h1 class="portfolio-title">Portfolio <em>Exhibition</em></h1>
    </header>

    <section class="story-gallery-sec" id="gallery-section">
      <div class="masonry-grid">
        {IMAGES.map((src, i) => (
          <div class="gallery-item" data-index={i}>
            <div class="gallery-item-inner">
              <img
                src={src}
                alt={`Wedding Candid ${i + 1}`}
                loading={i < 4 ? 'eager' : 'lazy'}
              />
            </div>
          </div>
        ))}
      </div>
    </section>

    <footer class="portfolio-footer">
      <span>— Wedding Candid Portfolio —</span>
    </footer>

    <!-- Light Lightbox -->
    <div id="portfolioLightbox" class="port-lightbox" hidden>
      <div class="port-lb-header">
        <span class="port-lb-counter" id="portCounter"></span>
        <button class="port-lb-close" id="portClose">✕</button>
      </div>
      <div class="port-lb-stage">
        <button class="port-lb-arrow prev" id="portPrev">&#8592;</button>
        <div class="port-lb-img-wrap">
          <img id="portLbBg" class="port-lb-bg" src="" alt="" aria-hidden="true" />
          <img id="portLbImg" src="" alt="Portfolio View" />
        </div>
        <button class="port-lb-arrow next" id="portNext">&#8594;</button>
      </div>
    </div>
  </article>
</Layout>

<style>
  :root {
    --paper: #f5f1eb;
    --ink: #1a1814;
    --gold: #b68b40;
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
  }

  .portfolio-exhibition {
    background: var(--paper);
    color: var(--ink);
    min-height: 100vh;
    padding: 100px 0 0;
  }

  .portfolio-header {
    text-align: center;
    margin-bottom: 60px;
    padding: 0 2rem;
  }

  .portfolio-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.5rem;
  }
  .portfolio-title em { font-style: italic; color: var(--gold); }

  /* ── Masonry Grid ── */
  .story-gallery-sec {
    --grid-gap: 0.8vw;
    padding: 0 2vw 6rem;
  }
  .masonry-grid {
    column-count: 3;
    column-gap: var(--grid-gap);
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .masonry-grid { column-count: 2; }
    .story-gallery-sec { --grid-gap: 2vw; padding: 0 4vw 4rem; }
  }
  @media (max-width: 480px) {
    .masonry-grid { column-count: 1; }
    .story-gallery-sec { --grid-gap: 4vw; padding: 0 5vw 3rem; }
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: var(--grid-gap);
    overflow: hidden;
    background: #e8e4de;
    cursor: zoom-in;
    min-height: 80px;
  }
  .gallery-item-inner { position: relative; width: 100%; height: 100%; }
  .gallery-item img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.8s var(--ease);
  }
  .gallery-item:hover img { transform: scale(1.04); }

  .portfolio-footer {
    text-align: center;
    padding: 80px 2rem;
    font-family: var(--font-serif);
    font-size: 0.85rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  /* ── Immersive Lightbox ── */
  .port-lightbox {
    position: fixed;
    inset: 0;
    z-index: 100000;
    background: #000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s var(--ease), visibility 0.4s;
    overflow: hidden;
  }
  .port-lightbox.open { opacity: 1; visibility: visible; }

  .port-lb-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    padding: 0 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 20;
    background: linear-gradient(to bottom, rgba(0,0,0,0.4), transparent);
    pointer-events: none;
  }
  .port-lb-counter {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: #fff;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }
  .port-lb-close {
    background: none;
    border: none;
    font-size: 1.8rem;
    color: #fff;
    cursor: pointer;
    opacity: 0.8;
    transition: opacity 0.2s, transform 0.2s;
    line-height: 1;
    padding: 1rem;
    pointer-events: auto;
  }
  .port-lb-close:hover { opacity: 1; transform: scale(1.1); }

  .port-lb-stage {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin: 0;
    overflow: hidden;
  }

  .port-lb-img-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  
  .port-lb-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(80px) brightness(0.4);
    opacity: 0;
    transition: opacity 0.8s var(--ease);
    z-index: 1;
    transform: scale(1.1);
  }

  #portLbImg {
    display: block;
    transition: opacity 0.3s ease, transform 0.5s var(--ease);
    will-change: transform, opacity;
    position: relative;
    z-index: 2;
  }

  /* Orientation Logic */
  .port-lightbox.is-landscape #portLbImg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .port-lightbox.is-landscape .port-lb-bg {
    opacity: 0;
  }

  .port-lightbox.is-portrait #portLbImg {
    width: auto;
    height: 100vh;
    max-width: 100%;
    object-fit: contain;
  }
  .port-lightbox.is-portrait .port-lb-bg {
    opacity: 1;
  }

  .port-lb-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(0,0,0,0.2);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s var(--ease);
  }
  .port-lb-arrow:hover {
    background: #fff;
    color: #000;
    border-color: #fff;
    transform: translateY(-50%) scale(1.1);
  }

  .port-lb-arrow.prev { left: 3rem; }
  .port-lb-arrow.next { right: 3rem; }

  @media (max-width: 768px) {
    .port-lb-header { padding: 0 1.5rem; height: 60px; }
    .port-lb-arrow { width: 45px; height: 45px; font-size: 1.1rem; }
    .port-lb-arrow.prev { left: 1rem; }
    .port-lb-arrow.next { right: 1rem; }
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const lightbox = document.getElementById('portfolioLightbox');
    const lbImg    = document.getElementById('portLbImg');
    const lbBg     = document.getElementById('portLbBg');
    const counter  = document.getElementById('portCounter');
    const closeBtn = document.getElementById('portClose');
    const prevBtn  = document.getElementById('portPrev');
    const nextBtn  = document.getElementById('portNext');
    const items    = Array.from(document.querySelectorAll('.gallery-item'));
    const srcs     = items.map(it => it.querySelector('img').src);
    const total    = srcs.length;
    let cIdx       = 0;

    if (!lightbox || !items.length) return;

    // ── Apply real aspect ratio from each image's natural dimensions ──
    items.forEach(item => {
      const img = item.querySelector('img');

      const applyRatio = () => {
        const w = img.naturalWidth;
        const h = img.naturalHeight;
        if (w && h) {
          item.style.aspectRatio = `${w} / ${h}`;
        }
      };

      if (img.complete && img.naturalWidth) {
        applyRatio();
      } else {
        img.addEventListener('load', applyRatio, { once: true });
      }
    });

    // ── Lightbox ──
    function updateLb() {
      const src = srcs[cIdx];
      lbImg.src = src;
      lbBg.src  = src;
      counter.textContent = String(cIdx + 1).padStart(2, '0') + ' — ' + String(total).padStart(2, '0');

      // Detect orientation
      const tempImg = new Image();
      tempImg.src = src;
      tempImg.onload = () => {
        lightbox.classList.remove('is-landscape', 'is-portrait');
        if (tempImg.naturalWidth > tempImg.naturalHeight) {
          lightbox.classList.add('is-landscape');
        } else {
          lightbox.classList.add('is-portrait');
        }
      };
    }

    function openLb(i) {
      cIdx = i;
      updateLb();
      lightbox.removeAttribute('hidden');
      requestAnimationFrame(() => lightbox.classList.add('open'));
      document.body.style.overflow = 'hidden';
    }

    function closeLb() {
      lightbox.classList.remove('open');
      setTimeout(() => {
        lightbox.setAttribute('hidden', '');
        document.body.style.overflow = '';
      }, 420);
    }

    function navigate(dir) {
      cIdx = (cIdx + dir + total) % total;
      lbImg.style.opacity = '0';
      lbImg.style.transform = 'scale(1.05)';
      setTimeout(() => {
        updateLb();
        lbImg.style.opacity = '1';
        lbImg.style.transform = 'scale(1)';
      }, 180);
    }

    items.forEach((item, i) => item.addEventListener('click', () => openLb(i)));
    closeBtn.addEventListener('click', closeLb);
    prevBtn.addEventListener('click', () => navigate(-1));
    nextBtn.addEventListener('click', () => navigate(1));

    lightbox.addEventListener('click', e => {
      if (e.target === lightbox || e.target.classList.contains('port-lb-stage')) closeLb();
    });

    document.addEventListener('keydown', e => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'ArrowLeft')  navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
      if (e.key === 'Escape')     closeLb();
    });
  });
</script>