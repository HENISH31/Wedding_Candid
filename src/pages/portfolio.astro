---
import Layout from '../layouts/Layout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import StickyCopyright from '../components/StickyCopyright.astro';
import DomeGallery from '../components/DomeGallery';

// Dynamically fetch images for the quick portfolio
const globImages = import.meta.glob<{ default: ImageMetadata }>('/public/images/gallery/quick-portfolio/**/*.{jpeg,jpg,png,gif,webp,JPG,JPEG,PNG,GIF,WEBP}');
const myImagesKeys = Object.keys(globImages);

const loadedImages = await Promise.all(myImagesKeys.map(async key => {
  try {
    const mod = await globImages[key]();
    return {
      src: key.replace('/public', ''),
      metadata: mod.default
    };
  } catch(e) { return null; }
}));

const validImages = loadedImages.filter(img => img !== null);
---

<Layout hideGlobalPreloader={true} navTheme="dark">
  <article class="portfolio-exhibition">
    <header class="portfolio-header">
      <!-- Minimalist Header -->
    </header>

    <section class="dome-gallery-section">
      <div class="dome-wrapper">
        <DomeGallery 
          client:only="react" 
          images={validImages.map(img => ({ src: img.src, alt: "Wedding Candid Portfolio" }))}
          fit={1.2}
          grayscale={false}
          imageBorderRadius="12px"
          openedImageBorderRadius="8px"
          overlayBlurColor="#0a0a0c"
        />
      </div>
    </section>

    <footer class="portfolio-footer">
      <span class="copyright-text">© 2026 Wedding Candid — All images & videos are copyrighted</span>
    </footer>

  </article>
</Layout>

<style>
  :root {
    --paper: #0a0a0c;
    --ink: #f0f0f0;
    --gold: #d4af37;
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
    --galaxy-deep: #050508;
  }

  .portfolio-exhibition {
    position: fixed;
    inset: 0;
    z-index: 5;
    background: #000;
    background-image: 
      radial-gradient(circle at 50% 50%, rgba(30, 30, 45, 0.4), transparent 80%),
      radial-gradient(circle at 20% 30%, rgba(50, 20, 70, 0.2), transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(20, 40, 80, 0.2), transparent 50%);
    color: #fff;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  /* ── Star Field ── */
  .portfolio-exhibition::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(1px 1px at 10% 20%, #ffffff, transparent),
      radial-gradient(1px 1px at 30% 50%, #ffffff, transparent),
      radial-gradient(1.5px 1.5px at 50% 80%, #ffffff, transparent),
      radial-gradient(1px 1px at 70% 30%, #ffffff, transparent),
      radial-gradient(2px 2px at 85% 65%, #ffffff, transparent),
      radial-gradient(1px 1px at 25% 75%, #ffffff, transparent),
      radial-gradient(1.5px 1.5px at 15% 10%, #ffffff, transparent),
      radial-gradient(1px 1px at 60% 15%, #ffffff, transparent),
      radial-gradient(1px 1px at 45% 90%, #ffffff, transparent),
      radial-gradient(1.5px 1.5px at 95% 40%, #ffffff, transparent);
    background-size: 300px 300px;
    opacity: 0.3;
    pointer-events: none;
    animation: twinkling 10s infinite linear;
  }

  @keyframes twinkling {
    0% { opacity: 0.2; }
    50% { opacity: 0.4; }
    100% { opacity: 0.2; }
  }

  .portfolio-header {
    text-align: center;
    position: absolute;
    top: 40px;
    left: 0;
    right: 0;
    z-index: 10;
    pointer-events: none;
  }

  .dome-gallery-section {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 2000px;
    transform-style: preserve-3d;
  }
  .dome-wrapper {
    width: 100%;
    height: 100%;
    transform: translateZ(0);
    will-change: transform;
    transform-style: preserve-3d;
  }

  @media (max-width: 768px) {
    .dome-gallery-section {
      height: 100%;
    }
  }

  .portfolio-footer {
    position: absolute;
    bottom: 25px;
    left: 0;
    right: 0;
    text-align: center;
    z-index: 10;
    pointer-events: none;
    background: transparent !important;
  }
  .copyright-text {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(212, 175, 55, 0.5);
    display: block;
  }

  /* Hide global layout footer */
  :global(footer:not(.portfolio-footer)) {
    display: none !important;
  }
</style>


