---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import IconsSection from '../components/IconsSection.astro';
import DynamicHeroText from '../components/DynamicHeroText.astro';
import Marquee from '../components/Marquee.astro';
---

<Layout hideGlobalPreloader={true}>
  <Hero />

  <!-- Elegant Marquee Divider -->
  <Marquee />

  <IconsSection />

  <!-- Categories Section -->
  <section id="portfolio-categories" class="section categories-section stagger-reveal">
    <div class="section-header" style="text-align: center; margin-bottom: 2rem;">
      <p style="letter-spacing: 0.3rem; margin-bottom: 1rem;">DISCOVER</p>
      <h2 style="font-size: 3.5rem;">Portfolio Collections</h2>
    </div>
    <div class="collections-masonry-grid">
      <div class="collection-item stagger-reveal" onclick="window.location.href='/photography?filter=prewedding'">
        <div class="collection-img curtain-reveal"><img src="/gallery/opt/MBJ_5953.webp" loading="lazy" alt="Pre-Wedding" width="400" height="500"></div>
        <h4>PRE-WEDDING</h4>
      </div>
      
      <div class="collection-item tall stagger-reveal" onclick="window.location.href='/photography?filter=wedding'">
        <div class="collection-img curtain-reveal"><img src="/gallery/opt/WC_13299.webp" loading="lazy" alt="Wedding" width="400" height="700"></div>
        <h4>WEDDING + ELOPEMENTS</h4>
      </div>

      <div class="collection-item stagger-reveal" onclick="window.location.href='/photography?filter=prewedding'">
        <div class="collection-img curtain-reveal"><img src="/homepage/DJI_0639.jpg" loading="lazy" alt="Engagement" width="400" height="500"></div>
        <h4>ENGAGEMENT + COUPLES</h4>
      </div>

      <div class="collection-item stagger-reveal" onclick="window.location.href='/photography?filter=portrait'">
        <div class="collection-img curtain-reveal"><img src="/gallery/opt/WC__6391.webp" loading="lazy" alt="Branding" width="400" height="500"></div>
        <h4>SMALL BUSINESS + BRANDING</h4>
      </div>

      <div class="collection-item stagger-reveal" onclick="window.location.href='/photography?filter=events'">
        <div class="collection-img curtain-reveal"><img src="/gallery/opt/SSP01330.webp" loading="lazy" alt="Events" width="400" height="500"></div>
        <h4>REHEARSALS + EVENTS</h4>
      </div>
    </div>
  </section>

</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    if (window.revealSections) window.revealSections();
  });
</script>
