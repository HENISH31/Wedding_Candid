---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedAlbum from '../components/FeaturedAlbum.astro';
import DynamicHeroText from '../components/DynamicHeroText.astro';
import Marquee from '../components/Marquee.astro';

const featuredImages = [
  { src: '/candid/1M4A8828.jpg', alt: 'Pre-Wedding Story', title: 'The Beginning' },
  { src: '/candid/CB8A0155.jpg', alt: 'Wedding Ceremony', title: 'Eternal Unions' },
  { src: '/candid/WC_13299.jpg', alt: 'Fine Art Portrait', title: 'The Ceremony' },
  { src: '/candid/IMG_4312.jpg', alt: 'Modern Soul', title: 'Modern Soul' },
  { src: '/candid/MBJ_5953.jpg', alt: 'Editorial Detail', title: 'Raw Portraits' }
];
---

<Layout hideGlobalPreloader={true}>
  <Hero />


  <section id="album-intro" class="album-intro stagger-reveal" style="padding: 15vh 2rem 10vh; background: #ffffff; text-align: center;">
    <div class="intro-container" style="max-width: 800px; margin: 0 auto;">
      <p class="intro-eyebrow" style="letter-spacing: 0.5rem; color: #b8935a; font-size: 0.72rem; margin-bottom: 2rem; text-transform: uppercase; font-family: 'Outfit', sans-serif;">Curated Exhibition</p>
      <h2 class="intro-title" style="font-family: 'Bodoni Moda', serif; font-size: clamp(2.5rem, 5vw, 4rem); margin-bottom: 2.5rem; color: #2a2118; font-weight: 400; letter-spacing: 0.05em;">Featured Work</h2>
      <p class="intro-para" style="font-family: 'Outfit', sans-serif; line-height: 2; color: #666; font-size: 1.15rem; font-weight: 300; letter-spacing: 0.02em;">
        A handpicked selection of our most poignant stories. From the quiet morning whispers to the grandeur of the celebration, these moments define the 'Wedding Candid' philosophy of minimalist luxury and authentic emotion.
      </p>
      <div style="width: 1px; height: 120px; background: linear-gradient(to bottom, #b8935a, transparent); margin: 4rem auto 0;"></div>
    </div>
  </section>

  <FeaturedAlbum />

  <!-- Elegant Marquee Divider -->
  <Marquee />

  <!-- Categories Section -->
  <section id="portfolio-categories" class="section categories-section stagger-reveal">
    <div class="section-header" style="text-align: center; margin-bottom: 4rem;">
      <p style="letter-spacing: 0.3rem; margin-bottom: 1rem;">DISCOVER</p>
      <h2 style="font-size: 3.5rem;">Portfolio Collections</h2>
    </div>
    <div class="collections-masonry-grid">
      <div class="collection-item stagger-reveal" onclick="window.location.href='/portfolio?filter=prewedding'">
        <div class="collection-img curtain-reveal"><img src="/candid/MBJ_5953.jpg" loading="lazy" alt="Pre-Wedding"></div>
        <h4>PRE-WEDDING</h4>
      </div>
      
      <div class="collection-item tall stagger-reveal" onclick="window.location.href='/portfolio?filter=wedding'">
        <div class="collection-img curtain-reveal"><img src="/candid/WC_13299.jpg" loading="lazy" alt="Wedding"></div>
        <h4>WEDDING + ELOPEMENTS</h4>
      </div>

      <div class="collection-item stagger-reveal" onclick="window.location.href='/portfolio?filter=prewedding'">
        <div class="collection-img curtain-reveal"><img src="/candid/CB8A0155.jpg" loading="lazy" alt="Engagement"></div>
        <h4>ENGAGEMENT + COUPLES</h4>
      </div>

      <div class="collection-item stagger-reveal" onclick="window.location.href='/portfolio?filter=portrait'">
        <div class="collection-img curtain-reveal"><img src="/candid/WC__6391.jpg" loading="lazy" alt="Branding"></div>
        <h4>SMALL BUSINESS + BRANDING</h4>
      </div>

      <div class="collection-item stagger-reveal" onclick="window.location.href='/portfolio?filter=events'">
        <div class="collection-img curtain-reveal"><img src="/candid/SSP01330.JPG" loading="lazy" alt="Events"></div>
        <h4>REHEARSALS + EVENTS</h4>
      </div>
    </div>
  </section>

  <section class="section testimonials-section stagger-reveal">
    <div id="testimonial-slider" class="testimonial-container">
      <div class="testimonial-slide active">
        <div class="client-img"><img src="/avatar_1.png" alt="Client"></div>
        <p class="client-quote">"Working with Parker was a dream. They didn't just take photos; they captured the invisible connection between us. Every frame feels like a memory tucked in silk."</p>
        <p class="client-name">— ELEANOR & JAMES</p>
      </div>
      <div class="testimonial-slide">
        <div class="client-img"><img src="/avatar_2.png" alt="Client"></div>
        <p class="client-quote">"The level of professionalism and artistic vision is unmatched. Our wedding gallery felt like a scene from a classic film. Simply breathtaking."</p>
        <p class="client-name">— MARCUS & SOPHIA</p>
      </div>
    </div>
    <div class="slider-dots">
      <span class="dot active" data-index="0"></span>
      <span class="dot" data-index="1"></span>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    if (window.revealSections) window.revealSections();
  });
</script>
