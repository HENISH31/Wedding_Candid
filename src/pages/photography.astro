---
import Layout from '../layouts/Layout.astro';

/**
 * photography.astro — The Central Hub (Decision Stage)
 * Three immersive gateways to specialized photography branches.
 */

const SECTIONS = [
  {
    id: 'wedding',
    title: 'WEDDINGS',
    subtitle: 'THE INTIMATE ARCHIVE',
    image: '/gallery/opt/CB8A0325.webp',
    link: '/photography/wedding',
    description: 'Formal, vertical, emotional storytelling.'
  },
  {
    id: 'pre-wedding',
    title: 'PRE-WEDDINGS',
    subtitle: 'THE CINEMATIC JOURNEY',
    image: '/gallery/opt/198A1445.webp',
    link: '/photography/pre-wedding',
    description: 'Adventurous, horizontal, film-reel memories.'
  },
  {
    id: 'bw',
    title: 'B/W NOIR',
    subtitle: 'THE NOIR ARCHIVE',
    image: '/gallery/opt/WC__6391.webp',
    link: '/photography/bw',
    description: 'The depth of light, shadow, and timeless elegance.'
  },
  {
    id: 'event',
    title: 'EVENTS',
    subtitle: 'MOMENTS IN MOTION',
    image: '/gallery/opt/MBJ_5953.webp',
    link: '/photography/events',
    description: 'Corporate, life, and the energy of now.'
  }
];
---

<Layout hideGlobalPreloader={true} navTheme="light">
  <article class="photo-hub">
    <div class="hub-container">
      {SECTIONS.map((sec, i) => (
        <a href={sec.link} class={`hub-panel panel-${sec.id}`}>
          <div class="panel-bg">
            <img src={sec.image} alt={sec.title} />
            <div class="panel-overlay"></div>
          </div>
          <div class="panel-content">
            <span class="panel-tag">{sec.subtitle}</span>
            <h2 class="panel-title">{sec.title}</h2>
            <p class="panel-desc">{sec.description}</p>
            <div class="explore-hint">EXPLORE EXHIBITION →</div>
          </div>
          <div class="panel-line"></div>
        </a>
      ))}
    </div>
  </article>
</Layout>

<style>
  :root {
    --paper: #f5f1eb; /* Light theme beige */
    --dark: #1a1814;
    --gold: #b68b40;
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
  }

  .photo-hub { height: 100vh; background: var(--paper); overflow: hidden; }
  .hub-container { display: flex; height: 100%; width: 100%; }

  .hub-panel { 
    flex: 1; position: relative; display: flex; align-items: center; justify-content: center; 
    text-decoration: none; overflow: hidden; transition: flex 0.8s var(--ease);
    border-right: 1px solid rgba(0,0,0,0.05);
  }
  .hub-panel:last-child { border-right: none; }
  .hub-panel:hover { flex: 1.5; }

  .panel-bg { position: absolute; inset: 0; z-index: 1; }
  .panel-bg img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.9) grayscale(100%); transition: 0.8s var(--ease); }
  .hub-panel:hover .panel-bg img { filter: brightness(1) grayscale(0%); transform: scale(1.05); }
  .panel-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(245,241,235, 0.9), transparent); opacity: 0.7; }
  
  .panel-content { position: relative; z-index: 5; text-align: center; color: var(--dark); padding: 2rem; transition: transform 0.6s var(--ease); }
  .hub-panel:hover .panel-content { transform: translateY(-20px); }

  .panel-tag { font-family: 'Outfit', sans-serif; font-size: 0.65rem; color: var(--gold); letter-spacing: 0.4em; display: block; margin-bottom: 2.5rem; }
  .panel-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300; letter-spacing: 0.1em; transition: 0.6s; color: var(--dark); }
  .hub-panel:hover .panel-title { color: var(--gold); letter-spacing: 0.15em; }
  
  .panel-desc { font-family: 'Outfit', sans-serif; font-size: 0.75rem; color: rgba(0,0,0,0.5); margin-top: 1.5rem; opacity: 0; transform: translateY(10px); transition: 0.6s 0.2s var(--ease); }
  .hub-panel:hover .panel-desc { opacity: 1; transform: translateY(0); }

  .explore-hint { font-family: 'Outfit', sans-serif; font-size: 0.65rem; color: var(--gold); letter-spacing: 0.2em; margin-top: 3.5rem; opacity: 0; transition: 0.6s 0.3s; }
  .hub-panel:hover {
    .explore-hint { opacity: 1; }
  }

  .panel-line { position: absolute; bottom: 0; left: 0; width: 0; height: 3px; background: var(--gold); transition: width 0.8s var(--ease); }
  .hub-panel:hover .panel-line { width: 100%; }

  @media (max-width: 900px) {
    .hub-container { flex-direction: column; }
    .hub-panel { flex: 1; border-right: none; border-bottom: 1px solid rgba(0,0,0,0.05); }
    .hub-panel:hover { flex: 1.2; }
    .panel-overlay { background: linear-gradient(to right, rgba(245,241,235, 0.9), transparent); }
  }
</style>
</style>
